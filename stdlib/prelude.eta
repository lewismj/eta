    do:adjustment-formula->string
    do:estimate-effect
    do:conditional-mean
    do:marginal-prob
    ;; ── std.fact_table ──────────────────────────────────────────────
    make-fact-table
    fact-table?
    fact-table-insert!
    fact-table-build-index!
    fact-table-query
    fact-table-ref
    fact-table-row-count
    fact-table-row
    fact-table-for-each
