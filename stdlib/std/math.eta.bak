;;; std/math.eta — Mathematical constants and helpers.
;;;
;;; Builtins already available: + - * / abs min max modulo remainder
;;;                             zero? positive? negative?
;;; This module adds constants and common helpers not provided as builtins.

(module std.math
  (export
    pi e
    square cube
    even? odd?
    sign clamp
    quotient
    gcd lcm
    floor ceiling truncate round
    expt
    sum product)
  (begin

    ;; ── Constants ───────────────────────────────────────────────────

    (define pi 3.141592653589793)
    (define e  2.718281828459045)

    ;; ── Basic helpers ───────────────────────────────────────────────

    (defun square (x) (* x x))
    (defun cube   (x) (* x x x))

    (defun even? (n) (= (modulo n 2) 0))
    (defun odd?  (n) (not (= (modulo n 2) 0)))

    ;; Returns -1, 0, or 1.
    (defun sign (x)
      (cond ((positive? x) 1)
            ((negative? x) -1)
            (#t 0)))

    ;; Restrict x to the range [lo, hi].
    (defun clamp (x lo hi)
      (min hi (max lo x)))

    ;; Integer division (truncating toward zero).
    (defun quotient (a b)
      (let ((r (/ a b)))
        ;; If both are integers and divide evenly, / returns fixnum.
        ;; Otherwise, truncate the float toward zero.
        (if (integer? r)
            r
            ;; manual truncate toward zero
            (if (negative? r)
                (- 0 (let ((pos (- 0 r)))
                        (- pos (modulo (let ((m (* pos 1.0))) m) 1.0))))
                (- r (modulo (* r 1.0) 1.0))))))

    ;; Greatest common divisor (Euclidean algorithm).
    (defun gcd (a b)
      (let ((a (abs a)) (b (abs b)))
        (if (= b 0) a (gcd b (modulo a b)))))

    ;; Least common multiple.
    (defun lcm (a b)
      (if (or (= a 0) (= b 0))
          0
          (abs (/ (* a b) (gcd a b)))))

    ;; ── Rounding (integer-producing) ────────────────────────────────
    ;; These operate on the float representation; for fixnums they are
    ;; identity.

    (defun floor (x)
      (if (integer? x) x
          (let ((t (- x (modulo (* x 1.0) 1.0))))
            (if (negative? x) (- t 1) t))))

    (defun ceiling (x)
      (if (integer? x) x
          (let ((f (floor x)))
            (+ f 1))))

    (defun truncate (x)
      (if (integer? x) x
          (if (negative? x) (ceiling x) (floor x))))

    (defun round (x)
      (if (integer? x) x
          (floor (+ x 0.5))))

    ;; ── Exponentiation ──────────────────────────────────────────────

    ;; Integer exponentiation by squaring (non-negative exp only).
    (defun expt (base exp)
      (cond
        ((= exp 0) 1)
        ((even? exp)
         (let ((half (expt base (/ exp 2))))
           (* half half)))
        (#t (* base (expt base (- exp 1))))))

    ;; ── Summation helpers ───────────────────────────────────────────

    ;; Sum a list of numbers.
    (defun sum (xs)
      (letrec ((loop (lambda (rest acc)
                       (if (null? rest)
                           acc
                           (loop (cdr rest) (+ acc (car rest)))))))
        (loop xs 0)))

    ;; Product of a list of numbers.
    (defun product (xs)
      (letrec ((loop (lambda (rest acc)
                       (if (null? rest)
                           acc
                           (loop (cdr rest) (* acc (car rest)))))))
        (loop xs 1)))

  ))

