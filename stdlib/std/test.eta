;;; std/test.eta — Lightweight test framework.
;;;
;;; Usage:
;;;   (import std.test)
;;;   (define results
;;;     (run (make-group "my suite"
;;;       (list
;;;         (make-test "addition" (lambda () (assert-equal 4 (+ 2 2))))
;;;         (make-test "truthy"  (lambda () (assert-true #t)))))))
;;;   (print-summary (summary results))
;;;
;;; TAP output:
;;;   (print-tap results)    ; emits TAP 13 to stdout
;;;
;;; JUnit XML output:
;;;   (print-junit results)  ; emits JUnit XML to stdout

(module std.test
  (export
    ;; Constructors
    make-test make-group
    ;; Runner
    run summary
    ;; Summary accessors
    summary-total summary-passed summary-failed
    ;; Assertions
    assert-true assert-false assert-equal assert-not-equal
    assert-approx-equal
    ;; Output
    print-summary print-tap print-junit)
  (begin

    ;; ── Data (tagged vectors via define-record-type) ────────────────

    (define-record-type test-case
      (make-test name thunk)
      test-case?
      (name test-name)
      (thunk test-thunk))

    (define-record-type test-group
      (make-group name children)
      test-group?
      (name group-name)
      (children group-children))

    (define-record-type test-result
      (__make-result name status error)
      test-result?
      (name result-name)
      (status result-status)
      (error result-error))

    (define-record-type group-result
      (__make-group-result name status children)
      group-result?
      (name gresult-name)
      (status gresult-status)
      (children gresult-children))

    (define-record-type test-summary
      (__make-summary total passed failed)
      test-summary?
      (total summary-total)
      (passed summary-passed)
      (failed summary-failed))

    ;; ── Local helpers (no imports needed) ────────────────────────────

    (defun __map (f xs)
      (if (null? xs)
          '()
          (cons (f (car xs)) (__map f (cdr xs)))))

    (defun __foldl (f acc xs)
      (if (null? xs)
          acc
          (__foldl f (f acc (car xs)) (cdr xs))))

    ;; ── Assertions ──────────────────────────────────────────────────

    (defun assert-true (x . rest)
      (let ((msg (if (null? rest) "expected true" (car rest))))
        (if x 'ok (error msg))))

    (defun assert-false (x . rest)
      (let ((msg (if (null? rest) "expected false" (car rest))))
        (if x (error msg) 'ok)))

    (defun __val->string (x)
      (let ((p (open-output-string)))
        (display x p)
        (get-output-string p)))

    (defun assert-equal (expected actual . rest)
      (let ((msg (if (null? rest)
                     (string-append "expected "
                       (__val->string expected)
                       " but got "
                       (__val->string actual))
                     (car rest))))
        (if (equal? expected actual)
            'ok
            (error msg))))

    (defun assert-not-equal (a b . rest)
      (let ((msg (if (null? rest) "expected values to differ" (car rest))))
        (if (equal? a b) (error msg) 'ok)))

    (defun assert-approx-equal (expected actual . rest)
      (let ((tol (if (null? rest) 1e-9 (car rest))))
        (let ((diff (if (> expected actual)
                        (- expected actual)
                        (- actual expected))))
          (if (> diff tol)
              (error (string-append "expected approx "
                       (__val->string expected)
                       " but got "
                       (__val->string actual)
                       " (diff="
                       (__val->string diff)
                       ")"))
              'ok))))

    ;; ── Runner ──────────────────────────────────────────────────────

    (defun __run-test (t)
      ;; Execute the thunk; on success return pass, on error return fail.
      ;; NOTE: Until try/catch exists, a failing assertion (error) will
      ;; propagate up. For now, tests either all pass or abort on first failure.
      (begin
        ((test-thunk t))
        (__make-result (test-name t) 'pass '())))

    (defun __all-pass? (rs)
      (if (null? rs)
          #t
          (let ((st (if (test-result? (car rs))
                        (result-status (car rs))
                        (gresult-status (car rs)))))
            (if (eq? st 'pass)
                (__all-pass? (cdr rs))
                #f))))

    (defun __run-group (g)
      (let ((kids (__map run (group-children g))))
        (let ((status (if (__all-pass? kids) 'pass 'fail)))
          (__make-group-result (group-name g) status kids))))

    (defun run (node)
      (if (test-case? node)
          (__run-test node)
          (__run-group node)))

    ;; ── Summary ─────────────────────────────────────────────────────

    (defun __add-summary (a b)
      (__make-summary
        (+ (summary-total a)  (summary-total b))
        (+ (summary-passed a) (summary-passed b))
        (+ (summary-failed a) (summary-failed b))))

    (defun __count-results (res)
      (if (test-result? res)
          (if (eq? (result-status res) 'pass)
              (__make-summary 1 1 0)
              (__make-summary 1 0 1))
          ;; group result — fold children
          (__foldl __add-summary
                   (__make-summary 0 0 0)
                   (__map __count-results (gresult-children res)))))

    (defun summary (res)
      (__count-results res))

    ;; Print a human-readable summary line.
    (defun print-summary (s)
      (display (summary-total s))
      (display " tests, ")
      (display (summary-passed s))
      (display " passed, ")
      (display (summary-failed s))
      (display " failed")
      (newline))

    ;; ── TAP 13 output ───────────────────────────────────────────────
    ;;
    ;; Emits TAP version 13 format that can be consumed by VS Code
    ;; Test Explorer (via a TAP parser) and IntelliJ (via tap-junit).
    ;;
    ;; Format:
    ;;   TAP version 13
    ;;   1..N
    ;;   ok 1 - test name
    ;;   not ok 2 - test name
    ;;     ---
    ;;     message: error message
    ;;     ...

    (defun __tap-collect-results (res acc)
      ;; Flatten all test-results from nested group-results into a list.
      (if (test-result? res)
          (cons res acc)
          ;; group result — recurse children
          (__foldl (lambda (a child) (__tap-collect-results child a))
                   acc
                   (gresult-children res))))

    (defun __tap-print-result (idx r)
      (if (eq? (result-status r) 'pass)
          (begin
            (display "ok ")
            (display idx)
            (display " - ")
            (display (result-name r))
            (newline))
          (begin
            (display "not ok ")
            (display idx)
            (display " - ")
            (display (result-name r))
            (newline)
            (display "  ---")
            (newline)
            (display "  message: ")
            (display (result-error r))
            (newline)
            (display "  ...")
            (newline))))

    (defun __tap-print-all (results idx)
      (if (null? results)
          'done
          (begin
            (__tap-print-result idx (car results))
            (__tap-print-all (cdr results) (+ idx 1)))))

    (defun print-tap (res)
      ;; res is the result of (run ...).
      (let ((flat (reverse (__tap-collect-results res '()))))
        (let ((n (length flat)))
          (display "TAP version 13")
          (newline)
          (display "1..")
          (display n)
          (newline)
          (__tap-print-all flat 1))))

    ;; ── JUnit XML output ────────────────────────────────────────────
    ;;
    ;; Emits JUnit XML that can be imported by IntelliJ / CI systems.

    (defun __xml-escape (s)
      ;; Minimal XML escaping for attribute/text values.
      ;; Uses string-ref / string-length and eqv? to avoid char=? / string->list.
      (let ((p (open-output-string))
            (n (string-length s)))
        (let loop ((i 0))
          (if (= i n)
              (get-output-string p)
              (begin
                (let ((c (string-ref s i)))
                  (cond
                    ((eqv? c #\&)  (display "&amp;"  p))
                    ((eqv? c #\<)  (display "&lt;"   p))
                    ((eqv? c #\>)  (display "&gt;"   p))
                    ((eqv? c #\")  (display "&quot;" p))
                    (else          (display c p))))
                (loop (+ i 1)))))))

    (defun __junit-print-result (r)
      (if (eq? (result-status r) 'pass)
          (begin
            (display "    <testcase name=\"")
            (display (__xml-escape (result-name r)))
            (display "\"/>")
            (newline))
          (begin
            (display "    <testcase name=\"")
            (display (__xml-escape (result-name r)))
            (display "\">")
            (newline)
            (display "      <failure message=\"")
            (display (__xml-escape (__val->string (result-error r))))
            (display "\"/>")
            (newline)
            (display "    </testcase>")
            (newline))))

    (defun __junit-print-all (results)
      (if (null? results)
          'done
          (begin
            (__junit-print-result (car results))
            (__junit-print-all (cdr results)))))

    (defun print-junit (res . suite-name-rest)
      (let ((suite-name (if (null? suite-name-rest) "eta-tests" (car suite-name-rest))))
        (let ((flat (reverse (__tap-collect-results res '()))))
          (let ((s (summary res)))
            (display "<?xml version=\"1.0\" encoding=\"UTF-8\"?>")
            (newline)
            (display "<testsuite name=\"")
            (display (__xml-escape suite-name))
            (display "\" tests=\"")
            (display (summary-total s))
            (display "\" failures=\"")
            (display (summary-failed s))
            (display "\">")
            (newline)
            (__junit-print-all flat)
            (display "</testsuite>")
            (newline)))))

  ))
