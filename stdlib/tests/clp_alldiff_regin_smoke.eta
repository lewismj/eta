;;; clp_alldiff_regin_smoke.eta — Phase 4b smoke test for the native
;;; Régin value-graph matching all-different propagator.
;;;
;;; Verifies that the native `clp:all-different` (now backed by
;;; `%clp-fd-all-different!`) performs domain-consistent pruning —
;;; strictly stronger than pairwise forward-checking:
;;;
;;;   X ∈ {1,2}, Y ∈ {1,2}, Z ∈ {1,2,3}, all-different(X,Y,Z)
;;;     pairwise AC-3  →  Z unchanged {1,2,3}
;;;     Régin          →  Z narrows to {3}  (1 and 2 are consumed by X,Y)

(module clp-alldiff-regin-smoke
  (import std.core std.collections std.logic std.clp)
  (begin

    (define fail-count 0)

    (defun chk (label expected actual)
      (display label) (display " => ") (display actual)
      (if (equal? actual expected)
          (display "   [ok]")
          (begin (display "   [FAIL expected ")
                 (display expected) (display "]")
                 (set! fail-count (+ fail-count 1))))
      (newline))

    (display "clp alldiff (Régin) smoke: start") (newline)

    ;; ── 1. Canonical Régin-stronger-than-AC-3 pruning ────────────────
    ;; X,Y ∈ {1,2}, Z ∈ {1,2,3}, all-different ⇒ Z must be 3.
    (let ((x (logic-var)) (y (logic-var)) (z (logic-var)))
      (clp:in-fd x 1 2)
      (clp:in-fd y 1 2)
      (clp:in-fd z 1 2 3)
      (chk "all-different post" #t (clp:all-different (list x y z)))
      (chk "Z narrowed to {3} by Régin" 3 (deref-lvar z)))

    ;; ── 2. Feasibility: pigeonhole (4 vars in {1,2,3}) fails on post ──
    (let ((a (logic-var)) (b (logic-var))
          (c (logic-var)) (d (logic-var)))
      (clp:in-fd a 1 2 3) (clp:in-fd b 1 2 3)
      (clp:in-fd c 1 2 3) (clp:in-fd d 1 2 3)
      (chk "pigeonhole UNSAT detected at post time" #f
           (clp:all-different (list a b c d))))

    ;; ── 3. Two ground vars with same value fail immediately ─────────
    (let ((x (logic-var)) (y (logic-var)) (z (logic-var)))
      (unify x 5)
      (unify y 5)
      (clp:in-fd z 1 5 9)
      (chk "dup ground values → fail" #f
           (clp:all-different (list x y z))))

    ;; ── 4. Ground values prune siblings ─────────────────────────────
    (let ((x (logic-var)) (y (logic-var)) (z (logic-var)))
      (unify x 2)
      (clp:in-fd y 1 2 3)
      (clp:in-fd z 2 3 4)
      (clp:all-different (list x y z))
      (chk "Y excludes 2" '(fd 1 3) (%clp-get-domain y))
      (chk "Z excludes 2" '(fd 3 4) (%clp-get-domain z)))

    ;; ── 5. Re-fires on bind: narrowing happens inside unify ─────────
    ;; After posting on {X,Y,Z} ⊆ {1,2,3}, binding X=2 should prune 2
    ;; from both Y and Z via the re-firing hook.
    (let ((x (logic-var)) (y (logic-var)) (z (logic-var)))
      (clp:in-fd x 1 2 3)
      (clp:in-fd y 1 2 3)
      (clp:in-fd z 1 2 3)
      (clp:all-different (list x y z))
      (unify x 2)
      (chk "after X=2 bind, Y ∉ {2}" #f
           (member 2 (clp:domain-values (%clp-get-domain y))))
      (chk "after X=2 bind, Z ∉ {2}" #f
           (member 2 (clp:domain-values (%clp-get-domain z)))))

    ;; ── 6. Backtracking restores domains after failure ──────────────
    (let* ((x (logic-var)) (y (logic-var)) (z (logic-var))
           (_ (clp:in-fd x 1 2 3))
           (_ (clp:in-fd y 1 2 3))
           (_ (clp:in-fd z 1 2 3))
           (_ (clp:all-different (list x y z)))
           (m (trail-mark)))
      (unify x 1)
      (chk "after X=1 bind, Y pruned" '(fd 2 3)
           (%clp-get-domain y))
      (unwind-trail m)
      (chk "Y restored after unwind" '(fd 1 2 3)
           (%clp-get-domain y))
      (chk "X unbound after unwind" #t (logic-var? (deref-lvar x))))

    ;; ── 7. Latin square 4×4 still solvable under Régin ──────────────
    ;; 4 rows of 4 cells each, all-different per row and per column.
    ;; We sample a known starting config and verify feasibility via
    ;; labelling.
    (let ((c11 (logic-var)) (c12 (logic-var)) (c13 (logic-var)) (c14 (logic-var))
          (c21 (logic-var)) (c22 (logic-var)) (c23 (logic-var)) (c24 (logic-var))
          (c31 (logic-var)) (c32 (logic-var)) (c33 (logic-var)) (c34 (logic-var))
          (c41 (logic-var)) (c42 (logic-var)) (c43 (logic-var)) (c44 (logic-var)))
      (for-each
        (lambda (v) (clp:in-fd v 1 2 3 4))
        (list c11 c12 c13 c14 c21 c22 c23 c24
              c31 c32 c33 c34 c41 c42 c43 c44))
      (clp:all-different (list c11 c12 c13 c14))
      (clp:all-different (list c21 c22 c23 c24))
      (clp:all-different (list c31 c32 c33 c34))
      (clp:all-different (list c41 c42 c43 c44))
      (clp:all-different (list c11 c21 c31 c41))
      (clp:all-different (list c12 c22 c32 c42))
      (clp:all-different (list c13 c23 c33 c43))
      (clp:all-different (list c14 c24 c34 c44))
      (chk "4×4 Latin square solvable" #t
           (clp:labeling (list c11 c12 c13 c14 c21 c22 c23 c24
                               c31 c32 c33 c34 c41 c42 c43 c44)
                         'strategy 'ff)))

    ;; ── Summary ────────────────────────────────────────────────────
    (newline)
    (if (= fail-count 0)
        (display "clp alldiff (Régin) smoke: ALL PASS")
        (begin (display "clp alldiff (Régin) smoke: ")
               (display fail-count) (display " FAILURE(S)")))
    (newline)))

