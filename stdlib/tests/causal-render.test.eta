;;; stdlib/tests/causal-render.test.eta -- Tests for std.causal.render

(module causal.render.tests
  (import std.test
          std.causal.render
          std.core
          std.collections)
  (begin

    (defun contains? (text needle)
      (let ((n (string-length text))
            (m (string-length needle)))
        (if (= m 0)
            #t
            (if (< n m)
                #f
                (letrec ((loop (lambda (i)
                                 (if (> i (- n m))
                                     #f
                                     (if (string=? (substring text i (+ i m)) needle)
                                         #t
                                         (loop (+ i 1)))))))
                  (loop 0))))))

    (defun contains-edge? (g edge)
      (any? (lambda (e) (equal? e edge)) g))

    (define mixed-graph
      '((a -> b)
        (a <-> c)
        (b -- c)))

    (define validated-graph
      (define-dag '((x -> y)
                    (x <-> z))))

    (define suite
      (make-group "std.causal.render"
        (list

          (make-test "define-dag validates directed and bidirected edges"
            (lambda ()
              (assert-true (contains-edge? validated-graph '(x -> y)))
              (assert-true (contains-edge? validated-graph '(x <-> z)))))

          (make-test "dag:->dot renders title rankdir and mixed edges"
            (lambda ()
              (let ((s (dag:->dot mixed-graph
                                  '((title . "Risk Graph")
                                    (rankdir . "TB")))))
                (assert-true (contains? s "digraph \"Risk Graph\" {"))
                (assert-true (contains? s "rankdir=TB;"))
                (assert-true (contains? s "\"a\" -> \"b\";"))
                (assert-true (contains? s "\"a\" -> \"c\" [dir=both, style=dashed];"))
                (assert-true (contains? s "\"b\" -> \"c\" [dir=none];")))))

          (make-test "dag:->mermaid renders deterministic ids and edge styles"
            (lambda ()
              (let ((s (dag:->mermaid mixed-graph)))
                (assert-true (contains? s "flowchart LR"))
                (assert-true (contains? s "n0[\"a\"]"))
                (assert-true (contains? s "n1[\"b\"]"))
                (assert-true (contains? s "n2[\"c\"]"))
                (assert-true (contains? s "n0 --> n1"))
                (assert-true (contains? s "n0 -.-> n2"))
                (assert-true (contains? s "n2 -.-> n0"))
                (assert-true (contains? s "n1 --- n2")))))

          (make-test "dag:->latex renders causal operators"
            (lambda ()
              (let ((s (dag:->latex mixed-graph)))
                (assert-true (contains? s "\\mathcal{G}"))
                (assert-true (contains? s "\\texttt{a} \\to \\texttt{b}"))
                (assert-true (contains? s "\\leftrightarrow"))))))))

    (print-tap (run suite))))
