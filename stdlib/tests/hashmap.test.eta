;;; stdlib/tests/hashmap.test.eta - Tests for std.hashmap wrappers.

(module hashmap.tests
  (import std.test std.hashmap)
  (begin

    (define test-empty-constructor
      (make-test "hash-map empty constructor and predicate"
        (lambda ()
          (let ((m (make-hash-map)))
            (assert-true (hash-map? m))
            (assert-equal 0 (hash-map-size m))
            (assert-true (hash-map-empty? m))))))

    (define test-assoc-ref-dissoc
      (make-test "hash-map assoc/ref/dissoc"
        (lambda ()
          (let* ((m0 (make-hash-map))
                 (m1 (hash-map-assoc m0 'a 10))
                 (m2 (hash-map-assoc m1 'b 20))
                 (m3 (hash-map-dissoc m2 'a)))
            (assert-equal 2 (hash-map-size m2))
            (assert-equal 10 (hash-map-ref m2 'a))
            (assert-equal 20 (hash-map-ref m2 'b))
            (assert-equal 1 (hash-map-size m3))
            (assert-false (hash-map-contains? m3 'a))
            (assert-equal 20 (hash-map-ref m3 'b))))))

    (define test-numeric-key-distinction
      (make-test "hash-map keeps 1 and 1.0 as distinct keys"
        (lambda ()
          (let* ((m0 (make-hash-map))
                 (m1 (hash-map-assoc m0 1 'int))
                 (m2 (hash-map-assoc m1 1.0 'float)))
            (assert-equal 2 (hash-map-size m2))
            (assert-equal 'int (hash-map-ref m2 1))
            (assert-equal 'float (hash-map-ref m2 1.0))))))

    (define test-roundtrip-list
      (make-test "hash-map list roundtrip"
        (lambda ()
          (let* ((m1 (list->hash-map '((a . 1) (b . 2) (c . 3))))
                 (al (hash-map->alist m1))
                 (m2 (alist->hash-map al)))
            (assert-true (equal? m1 m2))
            (assert-equal 3 (hash-map-size m2))))))

    (define test-merge-update-map-filter
      (make-test "hash-map merge/update/map/filter wrappers"
        (lambda ()
          (let* ((m1 (hash-map 'a 1 'b 2))
                 (m2 (hash-map 'b 20 'c 3))
                 (merged (hash-map-merge m1 m2))
                 (merged-with (hash-map-merge-with + m1 m2))
                 (updated (hash-map-update-with-default m1 'z (lambda (x) (+ x 1)) 40))
                 (mapped (hash-map-map (lambda (_k v) (* v 10)) m1))
                 (filtered (hash-map-filter (lambda (_k v) (> v 1)) m1)))
            (assert-equal 3 (hash-map-size merged))
            (assert-equal 20 (hash-map-ref merged 'b))
            (assert-equal 22 (hash-map-ref merged-with 'b))
            (assert-equal 41 (hash-map-ref updated 'z))
            (assert-equal 10 (hash-map-ref mapped 'a))
            (assert-equal 20 (hash-map-ref mapped 'b))
            (assert-equal 1 (hash-map-size filtered))
            (assert-true (hash-map-contains? filtered 'b))
            (assert-false (hash-map-contains? filtered 'a))))))

    (define test-fold
      (make-test "hash-map-fold aggregates values"
        (lambda ()
          (let* ((m (hash-map 'x 1 'y 2 'z 3))
                 (total (hash-map-fold
                          (lambda (acc _k v) (+ acc v))
                          0
                          m)))
            (assert-equal 6 total)))))

    (define suite
      (make-group "std.hashmap"
        (list
          test-empty-constructor
          test-assoc-ref-dissoc
          test-numeric-key-distinction
          test-roundtrip-list
          test-merge-update-map-filter
          test-fold)))

    (print-tap (run suite))))
