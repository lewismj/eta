;;; stdlib/tests/causal-policy.test.eta -- Tests for std.causal.policy

(module causal.policy.tests
  (import std.test std.causal.policy std.stats std.core std.collections)
  (begin

    (defun make-row (z x y)
      (list
        (cons 'z z)
        (cons 'x x)
        (cons 'y y)))

    (defun repeat-row (n row)
      (let loop ((i 0) (acc '()))
        (if (= i n)
            (reverse acc)
            (loop (+ i 1) (cons row acc)))))

    (defun z-of (obs) (cdr (assq 'z obs)))

    (defun make-flat-data ()
      (let ((zs '(-2 -1 0 1 2)))
        (foldl
          (lambda (acc z)
            (append acc
                    (repeat-row 10 (make-row z 0 2.0))
                    (repeat-row 10 (make-row z 1 2.0))))
          '()
          zs)))

    ;; Balanced RCT with deterministic outcomes:
    ;;   y0(z) = 1 + 0.2*z
    ;;   y1(z) = y0(z) + 0.5 + 0.1*z
    (defun make-rct-data ()
      (let ((zs '(-2 -1 0 1 2)))
        (foldl
          (lambda (acc z)
            (let* ((y0 (+ 1.0 (* 0.2 z)))
                   (tau (+ 0.5 (* 0.1 z)))
                   (y1 (+ y0 tau)))
              (append acc
                      (repeat-row 6 (make-row z 0 y0))
                      (repeat-row 6 (make-row z 1 y1)))))
          '()
          zs)))

    (defun policy-positive-z (zrow)
      (if (>= (car zrow) 0) 1 0))

    (defun true-mu0 (z) (+ 1.0 (* 0.2 z)))
    (defun true-mu1 (z) (+ (true-mu0 z) (+ 0.5 (* 0.1 z))))

    (defun true-policy-value (data)
      (stats:mean
        (map* (lambda (obs)
                (let* ((z (z-of obs))
                       (a (policy-positive-z (list z))))
                  (if (= a 1)
                      (true-mu1 z)
                      (true-mu0 z))))
              data)))

    (define suite
      (make-group "std.causal.policy"
        (list

          (make-test "Qini coefficient is zero when treatment effect is identically zero"
            (lambda ()
              (let* ((d (make-flat-data))
                     (pred (map-indexed (lambda (i _o) (modulo (+ (* 7 i) 3) 11)) d))
                     (y (map* (lambda (o) (cdr (assq 'y o))) d))
                     (x (map* (lambda (o) (cdr (assq 'x o))) d))
                     (curve (policy:qini-curve pred y x)))
                (assert-approx-equal 0.0 (policy:qini-coefficient curve) 0.01)
                (let ((auuc (policy:auuc curve)))
                  (assert-true (>= auuc 0.0))
                  (assert-true (<= auuc 1.0))))))

          (make-test "Qini coefficient improves under informative ranking"
            (lambda ()
              (let* ((taus '(-2.0 -1.5 -1.0 -0.5 0.5 1.0 1.5 2.0))
                     (x '(0 1 0 1 0 1 0 1))
                     (y (map2 (lambda (tau xv)
                                (+ 2.0 (* xv tau)))
                              taus x))
                     (good taus)
                     (bad (reverse taus))
                     (q-good (policy:qini-coefficient (policy:qini-curve good y x)))
                     (q-bad (policy:qini-coefficient (policy:qini-curve bad y x))))
                (assert-true (> q-good q-bad)))))

          (make-test "AIPW and IPW policy values match true policy value on balanced RCT"
            (lambda ()
              (let* ((d (make-rct-data))
                     (mu0 (map* (lambda (obs) (true-mu0 (z-of obs))) d))
                     (mu1 (map* (lambda (obs) (true-mu1 (z-of obs))) d))
                     (e (map* (lambda (_obs) 0.5) d))
                     (truth (true-policy-value d))
                     (v-ipw (policy:value-ipw d 'y 'x '(z) policy-positive-z e))
                     (v-aipw (policy:value-aipw d 'y 'x '(z) policy-positive-z mu1 mu0 e)))
                (assert-approx-equal truth v-ipw 1e-9)
                (assert-approx-equal truth v-aipw 1e-9))))

          (make-test "Synthetic-truth diagnostics return expected values"
            (lambda ()
              (let* ((pehe (policy:pehe '(1.0 2.0 3.0) '(1.1 1.9 2.8)))
                     (rmse-list (policy:ate-rmse 2.0 '(1.8 2.0 2.2)))
                     (bias-list (policy:ate-bias 2.0 '(1.8 2.0 2.2)))
                     (rmse-scalar (policy:ate-rmse 2.0 1.7))
                     (bias-scalar (policy:ate-bias 2.0 1.7)))
                (assert-approx-equal 0.14142135623730953 pehe 1e-12)
                (assert-approx-equal 0.16329931618554525 rmse-list 1e-12)
                (assert-approx-equal 0.0 bias-list 1e-12)
                (assert-approx-equal 0.3 rmse-scalar 1e-12)
                (assert-approx-equal -0.3 bias-scalar 1e-12))))

          (make-test "Policy constructors produce expected treatment assignments"
            (lambda ()
              (let* ((taus '(0.7 -0.2 1.1 0.5))
                     (budget-half (policy:greedy-budget taus 0.5))
                     (budget-three (policy:greedy-budget taus 3))
                     (ranked (policy:rank-by-cate
                               (list (list (cons 'id 0))
                                     (list (cons 'id 1))
                                     (list (cons 'id 2))
                                     (list (cons 'id 3)))
                               taus))
                     (ranked-taus (cdr ranked)))
                (assert-equal 1 (policy:greedy-treat-positive 0.1))
                (assert-equal 0 (policy:greedy-treat-positive 0.0))
                (assert-equal 0 (policy:greedy-treat-positive -0.1))
                (assert-equal '(1 0 1 0) budget-half)
                (assert-equal '(1 0 1 1) budget-three)
                (assert-equal '(1.1 0.7 0.5 -0.2) ranked-taus)))))))

    (print-tap (run suite))))
