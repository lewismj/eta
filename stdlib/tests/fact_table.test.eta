;;; stdlib/tests/fact_table.test.eta - Unit tests for std.fact_table

(module fact-table.tests
  (import std.test std.fact_table std.io)
  (begin

    (defun fact-table:test-write-file (path text)
      (let ((p (open-output-file path)))
        (if p
            (begin
              (display text p)
              (close-output-port p)
              #t)
            #f)))

    (define suite
      (make-group "std.fact_table"
        (list
          ;; Construction
          (make-group "construction"
            (list
              (make-test "make-fact-table returns a fact-table"
                (lambda ()
                  (let ((ft (make-fact-table 'name 'age)))
                    (assert-true (fact-table? ft)))))
              (make-test "fact-table? false for non-table"
                (lambda ()
                  (assert-false (fact-table? 42))))
              (make-test "empty table has zero rows"
                (lambda ()
                  (let ((ft (make-fact-table 'x)))
                    (assert-equal 0 (fact-table-row-count ft)))))))

          ;; Insert / row-count
          (make-group "insert"
            (list
              (make-test "insert increases row count"
                (lambda ()
                  (let ((ft (make-fact-table 'a 'b)))
                    (fact-table-insert! ft 1 2)
                    (assert-equal 1 (fact-table-row-count ft)))))
              (make-test "insert multiple rows"
                (lambda ()
                  (let ((ft (make-fact-table 'a 'b)))
                    (fact-table-insert! ft 1 2)
                    (fact-table-insert! ft 3 4)
                    (fact-table-insert! ft 5 6)
                    (assert-equal 3 (fact-table-row-count ft)))))
              (make-test "fact-table-ref reads inserted value"
                (lambda ()
                  (let ((ft (make-fact-table 'x 'y)))
                    (fact-table-insert! ft 10 20)
                    (assert-equal 10 (fact-table-ref ft 0 0))
                    (assert-equal 20 (fact-table-ref ft 0 1)))))))

          ;; Index and query
          (make-group "query"
            (list
              (make-test "query without index returns matching rows"
                (lambda ()
                  (let ((ft (make-fact-table 'id 'val)))
                    (fact-table-insert! ft 1 100)
                    (fact-table-insert! ft 2 200)
                    (fact-table-insert! ft 1 300)
                    (fact-table-build-index! ft 0)
                    (let ((rows (fact-table-query ft 0 1)))
                      (assert-equal 2 (length rows))))))
              (make-test "query returns empty list for missing key"
                (lambda ()
                  (let ((ft (make-fact-table 'id)))
                    (fact-table-insert! ft 1)
                    (fact-table-build-index! ft 0)
                    (assert-equal '() (fact-table-query ft 0 99)))))))

          ;; Iteration
          (make-group "iteration"
            (list
              (make-test "fact-table-fold accumulates correctly"
                (lambda ()
                  (let ((ft (make-fact-table 'v)))
                    (fact-table-insert! ft 10)
                    (fact-table-insert! ft 20)
                    (fact-table-insert! ft 30)
                    (let ((total
                            (fact-table-fold ft
                              (lambda (acc i)
                                (+ acc (fact-table-ref ft i 0)))
                              0)))
                      (assert-equal 60 total)))))
              (make-test "fact-table-for-each visits every row"
                (lambda ()
                  (let ((ft (make-fact-table 'v))
                        (count-box (vector 0)))
                    (fact-table-insert! ft 1)
                    (fact-table-insert! ft 2)
                    (fact-table-for-each ft
                      (lambda (i)
                        (vector-set! count-box 0 (+ (vector-ref count-box 0) 1))))
                    (assert-equal 2 (vector-ref count-box 0)))))
              (make-test "fact-table-for-each skips tombstoned rows"
                (lambda ()
                  (let ((ft (make-fact-table 'v))
                        (seen-box (vector '())))
                    (fact-table-insert! ft 10)
                    (fact-table-insert! ft 20)
                    (fact-table-insert! ft 30)
                    (%fact-table-delete-row! ft 1)
                    (fact-table-for-each ft
                      (lambda (i)
                        (vector-set! seen-box 0 (cons i (vector-ref seen-box 0)))))
                    (assert-equal '(2 0) (vector-ref seen-box 0)))))
              (make-test "fact-table-fold skips tombstoned rows"
                (lambda ()
                  (let ((ft (make-fact-table 'v)))
                    (fact-table-insert! ft 10)
                    (fact-table-insert! ft 20)
                    (fact-table-insert! ft 30)
                    (%fact-table-delete-row! ft 1)
                    (let ((total
                            (fact-table-fold ft
                              (lambda (acc i)
                                (+ acc (fact-table-ref ft i 0)))
                              0)))
                      (assert-equal 40 total)))))))

          ;; Aggregation
          (make-group "aggregation"
            (list
              (make-test "fact-table-group-count groups live rows"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 2)
                    (fact-table-insert! ft 'b 3)
                    (%fact-table-delete-row! ft 1)
                    (let ((g (fact-table-group-count ft 0)))
                      (assert-equal 1 (cdr (assq 'a g)))
                      (assert-equal 1 (cdr (assq 'b g)))))))
              (make-test "fact-table-group-sum accumulates by key"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 3)
                    (fact-table-insert! ft 'b 2)
                    (let ((g (fact-table-group-sum ft 0 1)))
                      (assert-equal 4 (cdr (assq 'a g)))
                      (assert-equal 2 (cdr (assq 'b g)))))))
              (make-test "fact-table-group-sum promotes to flonum"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 2.5)
                    (let ((g (fact-table-group-sum ft 0 1)))
                      (assert-approx-equal 3.5 (cdr (assq 'a g)) 1e-10)))))
              (make-test "fact-table-group-by defaults to count and returns a table"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 2)
                    (fact-table-insert! ft 'b 3)
                    (%fact-table-delete-row! ft 1)
                    (let ((g (fact-table-group-by ft 0)))
                      (assert-true (fact-table? g))
                      (assert-equal 2 (fact-table-row-count g))
                      (let ((a-row (car (fact-table-query g 0 'a)))
                            (b-row (car (fact-table-query g 0 'b))))
                        (assert-equal 1 (fact-table-ref g a-row 1))
                        (assert-equal 1 (fact-table-ref g b-row 1)))))))
              (make-test "fact-table-group-by sum returns grouped sums in a table"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 3)
                    (fact-table-insert! ft 'b 2)
                    (let ((g (fact-table-group-by ft 0 'sum 1)))
                      (assert-equal 2 (fact-table-row-count g))
                      (let ((a-row (car (fact-table-query g 0 'a)))
                            (b-row (car (fact-table-query g 0 'b))))
                        (assert-equal 4 (fact-table-ref g a-row 1))
                        (assert-equal 2 (fact-table-ref g b-row 1)))))))
              (make-test "fact-table-partition returns per-key fact tables"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (fact-table-insert! ft 'a 2)
                    (fact-table-insert! ft 'b 3)
                    (%fact-table-delete-row! ft 1)
                    (let* ((parts (fact-table-partition ft 0))
                           (a-ft (cdr (assq 'a parts)))
                           (b-ft (cdr (assq 'b parts))))
                      (assert-true (fact-table? a-ft))
                      (assert-true (fact-table? b-ft))
                      (assert-equal 1 (fact-table-row-count a-ft))
                      (assert-equal 1 (fact-table-row-count b-ft))
                      (assert-equal 1 (fact-table-ref a-ft 0 1))
                      (assert-equal 3 (fact-table-ref b-ft 0 1))))))
              (make-test "fact-table-partition returns empty on out-of-range column"
                (lambda ()
                  (let ((ft (make-fact-table 'k 'v)))
                    (fact-table-insert! ft 'a 1)
                    (assert-equal '() (fact-table-partition ft 99)))))))

          ;; CSV bridge
          (make-group "csv bridge"
            (list
              (make-test "fact-table-load-csv infers numeric columns"
                (lambda ()
                  (let ((path "fact_table_load_csv_infer.csv"))
                    (assert-true
                      (fact-table:test-write-file
                        path
                        "sector,beta,ret\ntech,1.2,2.3\nenergy,0.9,1.1\n"))
                    (let ((ft (fact-table-load-csv path)))
                      (assert-true (fact-table? ft))
                      (assert-equal 2 (fact-table-row-count ft))
                      (assert-equal "tech" (fact-table-ref ft 0 0))
                      (assert-approx-equal 1.2 (fact-table-ref ft 0 1) 1e-12)
                      (assert-approx-equal 2.3 (fact-table-ref ft 0 2) 1e-12)))))
              (make-test "fact-table-load-csv infer-types? #f keeps numbers as strings"
                (lambda ()
                  (let ((path "fact_table_load_csv_strings.csv"))
                    (assert-true
                      (fact-table:test-write-file
                        path
                        "name,qty\nalpha,10\nbeta,20\n"))
                    (let ((ft (fact-table-load-csv path 'infer-types? #f)))
                      (assert-equal 2 (fact-table-row-count ft))
                      (assert-equal "10" (fact-table-ref ft 0 1))
                      (assert-equal "20" (fact-table-ref ft 1 1))))))
              (make-test "fact-table-save-csv round-trips live rows"
                (lambda ()
                  (let ((path "fact_table_save_csv_roundtrip.csv")
                        (ft (make-fact-table 'name 'score)))
                    (fact-table-insert! ft "alice" 10)
                    (fact-table-insert! ft "bob" 20)
                    (%fact-table-delete-row! ft 0)
                    (fact-table-save-csv ft path)
                    (let ((loaded (fact-table-load-csv path)))
                      (assert-equal 1 (fact-table-row-count loaded))
                      (assert-equal "bob" (fact-table-ref loaded 0 0))
                      (assert-equal 20 (fact-table-ref loaded 0 1))))))))))

    (print-tap (run suite)))))
