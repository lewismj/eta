;;; stdlib/tests/collections.test.eta — Unit tests for std.collections

(module collections.tests
  (import std.test std.collections std.math)
  (begin

    (define suite
      (make-group "std.collections"
        (list

          ;; ── filter ───────────────────────────────────────────────
          (make-group "filter"
            (list
              (make-test "filter even numbers"
                (lambda () (assert-equal '(2 4) (filter even? '(1 2 3 4 5)))))
              (make-test "filter all pass"
                (lambda () (assert-equal '(2 4 6) (filter even? '(2 4 6)))))
              (make-test "filter none pass"
                (lambda () (assert-equal '() (filter even? '(1 3 5)))))))

          ;; ── foldl / foldr ────────────────────────────────────────
          (make-group "fold"
            (list
              (make-test "foldl sum"
                (lambda () (assert-equal 10 (foldl + 0 '(1 2 3 4)))))
              (make-test "foldl build list"
                (lambda () (assert-equal '(3 2 1) (foldl cons '() '(1 2 3)))))
              (make-test "foldr sum"
                (lambda () (assert-equal 10 (foldr + 0 '(1 2 3 4)))))
              (make-test "foldr build list"
                (lambda () (assert-equal '(1 2 3) (foldr cons '() '(1 2 3)))))))

          ;; ── any? / every? ────────────────────────────────────────
          (make-group "predicates"
            (list
              (make-test "any? true"
                (lambda () (assert-true (any? even? '(1 2 3)))))
              (make-test "any? false"
                (lambda () (assert-false (any? even? '(1 3 5)))))
              (make-test "every? true"
                (lambda () (assert-true (every? even? '(2 4 6)))))
              (make-test "every? false"
                (lambda () (assert-false (every? even? '(2 3 4)))))
              (make-test "count"
                (lambda () (assert-equal 3 (count even? '(1 2 4 5 6)))))))

          ;; ── take / drop ──────────────────────────────────────────
          (make-group "take-drop"
            (list
              (make-test "take"
                (lambda () (assert-equal '(1 2 3) (take 3 '(1 2 3 4 5)))))
              (make-test "take zero"
                (lambda () (assert-equal '() (take 0 '(1 2 3)))))
              (make-test "drop"
                (lambda () (assert-equal '(4 5) (drop 3 '(1 2 3 4 5)))))
              (make-test "drop all"
                (lambda () (assert-equal '() (drop 5 '(1 2 3 4 5)))))))

          ;; ── zip / flatten ────────────────────────────────────────
          (make-group "zip-flatten"
            (list
              (make-test "zip"
                (lambda ()
                  (assert-equal '((1 . 4) (2 . 5) (3 . 6))
                                (zip '(1 2 3) '(4 5 6)))))
              (make-test "flatten"
                (lambda ()
                  (assert-equal '(1 2 3 4 5 6)
                                (flatten '((1 2) (3 4) (5 6))))))))

          ;; ── range ────────────────────────────────────────────────
          (make-group "range"
            (list
              (make-test "range basic"
                (lambda () (assert-equal '(0 1 2 3 4) (range 0 5))))
              (make-test "range empty"
                (lambda () (assert-equal '() (range 5 5))))
              (make-test "range subset"
                (lambda () (assert-equal '(2 3 4) (range 2 5))))))

          ;; ── sort ─────────────────────────────────────────────────
          (make-group "sort"
            (list
              (make-test "sort numbers ascending"
                (lambda () (assert-equal '(1 2 3 4 5) (sort < '(3 1 4 1 5)))))
              (make-test "sort numbers descending"
                (lambda () (assert-equal '(5 4 3 1 1) (sort > '(3 1 4 1 5)))))
              (make-test "sort already sorted"
                (lambda () (assert-equal '(1 2 3) (sort < '(1 2 3)))))))

          ;; ── vector operations ─────────────────────────────────────
          (make-group "vector"
            (list
              (make-test "vector-map"
                (lambda ()
                  (let ((v (vector 1 2 3)))
                    (let ((r (vector-map (lambda (x) (* x 2)) v)))
                      (assert-equal 2 (vector-ref r 0))
                      (assert-equal 4 (vector-ref r 1))
                      (assert-equal 6 (vector-ref r 2))))))
              (make-test "vector->list"
                (lambda ()
                  (assert-equal '(1 2 3) (vector->list (vector 1 2 3)))))
              (make-test "list->vector"
                (lambda ()
                  (let ((v (list->vector '(1 2 3))))
                    (assert-equal 1 (vector-ref v 0))
                    (assert-equal 3 (vector-length v)))))))))

    (print-tap (run suite)))))
