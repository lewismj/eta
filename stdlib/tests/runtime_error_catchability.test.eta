;;; stdlib/tests/runtime_error_catchability.test.eta
;;; Runtime-error catchability contract for catch/raise.

(module runtime_error_catchability.tests
  (import std.test)
  (begin

    (defun payload-tag (p) (car (cdr p)))
    (defun payload-msg (p) (car (cdr (cdr p))))
    (defun payload-span (p) (car (cdr (cdr (cdr p)))))
    (defun payload-trace (p) (car (cdr (cdr (cdr (cdr p))))))

    (define suite
      (make-group "runtime-error-catchability"
        (list
          (make-test "super-tag catches type error"
            (lambda ()
              (let ((p (catch 'runtime.error (car 42))))
                (assert-equal 'runtime-error (car p))
                (assert-equal 'runtime.type-error (payload-tag p))
                (assert-true (string? (payload-msg p))))))

          (make-test "specific subtype catches invalid arity"
            (lambda ()
              (let ((p (catch 'runtime.invalid-arity (car 1 2))))
                (assert-equal 'runtime.invalid-arity (payload-tag p))
                (assert-true (string? (payload-msg p))))))

          (make-test "tagless catch catches runtime errors"
            (lambda ()
              (let ((p (catch (car 42))))
                (assert-equal 'runtime.type-error (payload-tag p)))))

          (make-test "payload span is introspectable"
            (lambda ()
              (let ((spn (payload-span (catch 'runtime.error (car 42)))))
                (assert-equal 'span (car spn))
                (assert-true (number? (car (cdr spn))))
                (assert-true (number? (car (cdr (cdr spn)))))
                (assert-true (number? (car (cdr (cdr (cdr spn))))))
                (assert-true (number? (car (cdr (cdr (cdr (cdr spn)))))))
                (assert-true (number? (car (cdr (cdr (cdr (cdr (cdr spn)))))))))))

          (make-test "payload trace contains frame records"
            (lambda ()
              (let ((tr (payload-trace (catch 'runtime.error (car 42)))))
                (let ((fr (car tr)))
                  (let ((fsp (car (cdr (cdr fr)))))
                    (assert-equal 'frame (car fr))
                    (assert-true (string? (car (cdr fr))))
                    (assert-equal 'span (car fsp))))))))))

    (print-tap (run suite))))
