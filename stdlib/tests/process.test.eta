;;; stdlib/tests/process.test.eta - Unit tests for std.process.

(module process.tests
  (import std.test std.process)
  (begin

    (defun process:test-contains? (text needle)
      (let ((n (string-length text))
            (m (string-length needle)))
        (if (= m 0)
            #t
            (if (< n m)
                #f
                (letrec ((loop (lambda (i)
                                 (if (> i (- n m))
                                     #f
                                     (if (string=? (substring text i (+ i m)) needle)
                                         #t
                                         (loop (+ i 1)))))))
                  (loop 0))))))

    (defun process:windows? ()
      (equal? (platform) 'Win32))

    (defun process:cmd (program args)
      (list program args))

    (defun process:program (cmd)
      (car cmd))

    (defun process:args (cmd)
      (car (cdr cmd)))

    (defun process:second (xs)
      (car (cdr xs)))

    (defun process:third (xs)
      (car (cdr (cdr xs))))

    (defun process:payload-msg (p)
      (car (cdr (cdr p))))

    (defun process:run-out-err-cmd ()
      (if (process:windows?)
          (process:cmd "cmd" '("/c" "echo out& echo err 1>&2& exit /b 3"))
          (process:cmd "/bin/sh" '("-c" "echo out; echo err 1>&2; exit 3"))))

    (defun process:echo-cmd ()
      (if (process:windows?)
          (process:cmd "cmd" '("/c" "echo hello-process"))
          (process:cmd "/bin/echo" '("hello-process"))))

    (defun process:cat-cmd ()
      (if (process:windows?)
          (process:cmd "cmd" '("/c" "more"))
          (process:cmd "/bin/cat" '())))

    (defun process:sleep-cmd ()
      (if (process:windows?)
          (process:cmd "cmd" '("/c" "ping -n 3 127.0.0.1 >nul"))
          (process:cmd "/bin/sh" '("-c" "sleep 1"))))

    (defun process:env-cmd ()
      (if (process:windows?)
          (process:cmd "cmd" '("/c" "echo %ETA_PROCESS_STDLIB%"))
          (process:cmd "/bin/sh" '("-c" "printf '%s' \"$ETA_PROCESS_STDLIB\""))))

    (define suite
      (make-group "std.process"
        (list

          (make-test "process:run captures stdout stderr and status"
            (lambda ()
              (let* ((cmd (process:run-out-err-cmd))
                     (r (process:run (process:program cmd) (process:args cmd))))
                (assert-equal 3 (car r))
                (assert-true (process:test-contains? (process:second r) "out"))
                (assert-true (process:test-contains? (process:third r) "err")))))

          (make-test "process:run-string returns stdout text"
            (lambda ()
              (let ((cmd (process:echo-cmd)))
                (assert-true
                  (process:test-contains?
                    (process:run-string (process:program cmd) (process:args cmd))
                    "hello-process")))))

          (make-test "process:run supports stdin string data"
            (lambda ()
              (let* ((cmd (process:cat-cmd))
                     (r (process:run (process:program cmd)
                                     (process:args cmd)
                                     '((stdin . "eta-process-stdin")))))
                (assert-equal 0 (car r))
                (assert-true (process:test-contains? (process:second r) "eta-process-stdin")))))

          (make-test "process:spawn returns handle and stdio ports"
            (lambda ()
              (let* ((cmd (process:cat-cmd))
                     (h (process:spawn (process:program cmd) (process:args cmd))))
                (assert-true (process:handle? h))
                (assert-true (number? (process:pid h)))
                (assert-true (port? (process:stdin-port h)))
                (assert-true (port? (process:stdout-port h)))
                (assert-true (port? (process:stderr-port h)))
                (close-port (process:stdin-port h))
                (process:kill h)
                (assert-true (number? (process:wait h 3000))))))

          (make-test "process:wait returns #f on timeout"
            (lambda ()
              (let* ((cmd (process:sleep-cmd))
                     (h (process:spawn (process:program cmd) (process:args cmd))))
                (assert-equal #f (process:wait h 10))
                (process:kill h)
                (assert-true (number? (process:wait h 3000))))))

          (make-test "process:terminate transitions process state"
            (lambda ()
              (let* ((cmd (process:sleep-cmd))
                     (h (process:spawn (process:program cmd) (process:args cmd)))
                     (terminated (process:terminate h)))
                (assert-true (or (equal? #t terminated)
                                 (equal? #f terminated)))
                (assert-true (number? (process:wait h 3000)))
                (assert-equal #f (process:alive? h))
                (assert-true (number? (process:exit-code h))))))

          (make-test "process:run timeout uses stable error prefix"
            (lambda ()
              (let* ((cmd (process:sleep-cmd))
                     (p (catch 'runtime.error
                          (process:run (process:program cmd)
                                       (process:args cmd)
                                       '((timeout-ms . 10))))))
                (assert-equal 'runtime-error (car p))
                (assert-true
                  (process:test-contains?
                    (process:payload-msg p)
                    "process-timeout:")))))

          (make-test "process:run env option sets child environment"
            (lambda ()
              (let ((cmd (process:env-cmd)))
                (assert-true
                  (process:test-contains?
                    (process:run-string (process:program cmd)
                                        (process:args cmd)
                                        '((env . (("ETA_PROCESS_STDLIB" . "eta-process-env")))))
                    "eta-process-env")))))

          )))

    (print-tap (run suite))))
