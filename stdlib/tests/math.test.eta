;;; stdlib/tests/math.test.eta — Unit tests for std.math

(module math.tests
  (import std.test std.math)
  (begin

    (define suite
      (make-group "std.math"
        (list

          ;; ── Constants ────────────────────────────────────────────
          (make-group "constants"
            (list
              (make-test "pi is approximately 3.14159"
                (lambda () (assert-approx-equal 3.14159 pi 0.001)))
              (make-test "e is approximately 2.71828"
                (lambda () (assert-approx-equal 2.71828 e 0.001)))))

          ;; ── Basic helpers ─────────────────────────────────────────
          (make-group "helpers"
            (list
              (make-test "square"
                (lambda () (assert-equal 9 (square 3))))
              (make-test "cube"
                (lambda () (assert-equal 27 (cube 3))))
              (make-test "even? true"
                (lambda () (assert-true (even? 4))))
              (make-test "even? false"
                (lambda () (assert-false (even? 3))))
              (make-test "odd? true"
                (lambda () (assert-true (odd? 3))))
              (make-test "odd? false"
                (lambda () (assert-false (odd? 4))))
              (make-test "sign positive"
                (lambda () (assert-equal 1 (sign 5))))
              (make-test "sign negative"
                (lambda () (assert-equal -1 (sign -5))))
              (make-test "sign zero"
                (lambda () (assert-equal 0 (sign 0))))
              (make-test "clamp below"
                (lambda () (assert-equal 0 (clamp -5 0 10))))
              (make-test "clamp above"
                (lambda () (assert-equal 10 (clamp 15 0 10))))
              (make-test "clamp within"
                (lambda () (assert-equal 5 (clamp 5 0 10))))))

          ;; ── Integer functions ─────────────────────────────────────
          (make-group "integer"
            (list
              (make-test "quotient"
                (lambda () (assert-equal 3 (quotient 10 3))))
              (make-test "gcd"
                (lambda () (assert-equal 6 (gcd 12 18))))
              (make-test "lcm"
                (lambda () (assert-equal 36 (lcm 12 18))))))

          ;; ── Rounding ─────────────────────────────────────────────
          (make-group "rounding"
            (list
              (make-test "floor"
                (lambda () (assert-equal 3 (floor 3.7))))
              (make-test "ceiling"
                (lambda () (assert-equal 4 (ceiling 3.2))))
              (make-test "round up"
                (lambda () (assert-equal 4 (round 3.5))))
              (make-test "truncate"
                (lambda () (assert-equal 3 (truncate 3.9))))))

          ;; ── Exponentiation ───────────────────────────────────────
          (make-group "expt"
            (list
              (make-test "expt 2^3"
                (lambda () (assert-equal 8 (expt 2 3))))
              (make-test "expt 2^0"
                (lambda () (assert-equal 1 (expt 2 0))))
              (make-test "expt 5^2"
                (lambda () (assert-equal 25 (expt 5 2))))))

          ;; ── sum / product ─────────────────────────────────────────
          (make-group "sum-product"
            (list
              (make-test "sum"
                (lambda () (assert-equal 15 (sum '(1 2 3 4 5)))))
              (make-test "sum empty"
                (lambda () (assert-equal 0 (sum '()))))
              (make-test "product"
                (lambda () (assert-equal 120 (product '(1 2 3 4 5)))))
              (make-test "product empty"
                (lambda () (assert-equal 1 (product '()))))))))

    (print-tap (run suite)))))
