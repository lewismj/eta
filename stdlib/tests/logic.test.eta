;;; stdlib/tests/logic.test.eta — Unit tests for std.logic

(module logic.tests
  (import std.test std.logic)
  (begin

    (define suite
      (make-group "std.logic"
        (list

          ;; ── Basic unification ──────────────────────────────────────
          (make-group "unification"
            (list
              (make-test "unify two equal constants"
                (lambda ()
                  (assert-true (unify 42 42))))
              (make-test "unify unbound var with constant"
                (lambda ()
                  (let* ((x (logic-var))
                         (m (trail-mark))
                         (ok (unify x 99)))
                    (unwind-trail m)
                    (assert-true ok))))
              (make-test "unify two vars together"
                (lambda ()
                  (let* ((x (logic-var))
                         (y (logic-var))
                         (m (trail-mark))
                         (ok (unify x y)))
                    (unwind-trail m)
                    (assert-true ok))))
              (make-test "unify fails on different constants"
                (lambda ()
                  (assert-false (unify 1 2))))
              (make-test "deref after unification"
                (lambda ()
                  (let* ((x (logic-var))
                         (m (trail-mark)))
                    (unify x 7)
                    (let ((v (deref-lvar x)))
                      (unwind-trail m)
                      (assert-equal 7 v)))))
              (make-test "unwind-trail restores unbound state"
                (lambda ()
                  (let* ((x (logic-var))
                         (m (trail-mark)))
                    (unify x 42)
                    (unwind-trail m)
                    (assert-true (logic-var? x)))))))

          ;; ── == combinator ─────────────────────────────────────────
          (make-group "=="
            (list
              (make-test "== succeeds on equal constants"
                (lambda () (assert-true (== 1 1))))
              (make-test "== fails on different constants"
                (lambda () (assert-false (== 1 2))))
              (make-test "== binds variable"
                (lambda ()
                  (let* ((x (logic-var))
                         (m (trail-mark))
                         (ok (== x 5)))
                    (let ((v (deref-lvar x)))
                      (unwind-trail m)
                      (assert-equal 5 v)))))))

          ;; ── ground? ───────────────────────────────────────────────
          (make-group "ground?"
            (list
              (make-test "ground? on number"
                (lambda () (assert-true (ground? 42))))
              (make-test "ground? on symbol"
                (lambda () (assert-true (ground? 'foo))))
              (make-test "ground? on list of constants"
                (lambda () (assert-true (ground? '(1 2 3)))))
              (make-test "ground? false for unbound var"
                (lambda ()
                  (let ((x (logic-var)))
                    (assert-false (ground? x)))))))

          ;; ── naf / succeeds? ───────────────────────────────────────
          (make-group "naf-succeeds"
            (list
              (make-test "succeeds? on succeeding goal"
                (lambda ()
                  (assert-true (succeeds? (lambda () (== 1 1))))))
              (make-test "succeeds? on failing goal"
                (lambda ()
                  (assert-false (succeeds? (lambda () (== 1 2))))))
              (make-test "naf on failing goal returns true"
                (lambda ()
                  (assert-true (naf (lambda () (== 1 2))))))
              (make-test "naf on succeeding goal returns false"
                (lambda ()
                  (assert-false (naf (lambda () (== 1 1))))))
              (make-test "succeeds? unwinds bindings"
                (lambda ()
                  (let ((x (logic-var)))
                    (succeeds? (lambda () (== x 99)))
                    (assert-true (logic-var? x)))))))

          ;; ── findall ───────────────────────────────────────────────
          (make-group "findall"
            (list
              (make-test "findall collects all successes"
                (lambda ()
                  (let ((x (logic-var)))
                    (let ((results
                            (findall
                              (lambda () (deref-lvar x))
                              (list (lambda () (== x 1))
                                    (lambda () (== x 2))
                                    (lambda () (== x 3))))))
                      (assert-equal '(1 2 3) results)))))
              (make-test "findall skips failing branches"
                (lambda ()
                  (let ((x (logic-var)))
                    (let ((results
                            (findall
                              (lambda () (deref-lvar x))
                              (list (lambda () (== x 10))
                                    (lambda () (== 1 2))
                                    (lambda () (== x 30))))))
                      (assert-equal '(10 30) results)))))
              (make-test "findall on empty branches returns empty"
                (lambda ()
                  (assert-equal '()
                    (findall (lambda () 'x) '()))))))

          ;; ── run1 ──────────────────────────────────────────────────
          (make-group "run1"
            (list
              (make-test "run1 returns first solution"
                (lambda ()
                  (let ((x (logic-var)))
                    (let ((r (run1
                               (lambda () (deref-lvar x))
                               (list (lambda () (== x 'a))
                                     (lambda () (== x 'b))))))
                      (assert-equal 'a r)))))
              (make-test "run1 returns #f on no solution"
                (lambda ()
                  (let ((x (logic-var)))
                    (assert-false
                      (run1
                        (lambda () (deref-lvar x))
                        (list (lambda () (== 1 2))))))))))

          ;; ── membero ───────────────────────────────────────────────
          (make-group "membero"
            (list
              (make-test "membero enumerates all members"
                (lambda ()
                  (let ((x (logic-var)))
                    (assert-equal '(a b c)
                      (findall
                        (lambda () (deref-lvar x))
                        (membero x '(a b c)))))))
              (make-test "membero with bound var filters"
                (lambda ()
                  (let ((x (logic-var)))
                    (unify x 'b)
                    (let ((r (findall
                               (lambda () (deref-lvar x))
                               (membero x '(a b c)))))
                      (assert-equal '(b) r)))))))

          ;; ── named logic vars ───────────────────────────────────────
          (make-group "named-logic-vars"
            (list
              (make-test "logic-var/named returns an unbound var"
                (lambda ()
                  (let ((x (logic-var/named 'x)))
                    (assert-true (logic-var? x)))))
              (make-test "var-name returns the label string"
                (lambda ()
                  (let ((x (logic-var/named 'alpha)))
                    (assert-equal "alpha" (var-name x)))))
              (make-test "var-name is #f for anonymous vars"
                (lambda ()
                  (let ((x (logic-var)))
                    (assert-false (var-name x)))))
              (make-test "var-name is #f for non-vars"
                (lambda ()
                  (assert-false (var-name 42))))
              (make-test "logic-var/named accepts strings too"
                (lambda ()
                  (let ((x (logic-var/named "beta")))
                    (assert-equal "beta" (var-name x)))))
              (make-test "named vars unify like anonymous ones"
                (lambda ()
                  (let* ((x (logic-var/named 'x))
                         (m (trail-mark))
                         (ok (unify x 7))
                         (v (deref-lvar x)))
                    (unwind-trail m)
                    (assert-equal 7 v))))))

          ;; ── occurs-check toggle ────────────────────────────────────
          (make-group "occurs-check-toggle"
            (list
              (make-test "default mode is 'always"
                (lambda ()
                  (set-occurs-check! 'always)
                  (assert-equal 'always (occurs-check-mode))))
              (make-test "set to 'never is reported"
                (lambda ()
                  (set-occurs-check! 'never)
                  (let ((m (occurs-check-mode)))
                    (set-occurs-check! 'always)  ; restore default
                    (assert-equal 'never m))))
              (make-test "set to 'error is reported"
                (lambda ()
                  (set-occurs-check! 'error)
                  (let ((m (occurs-check-mode)))
                    (set-occurs-check! 'always)  ; restore default
                    (assert-equal 'error m))))
              (make-test "'always rejects cyclic binding"
                (lambda ()
                  (set-occurs-check! 'always)
                  (let* ((x (logic-var))
                         (m (trail-mark))
                         (ok (unify x (cons 1 x))))
                    (unwind-trail m)
                    (assert-false ok))))
              (make-test "'never admits cyclic binding"
                (lambda ()
                  (set-occurs-check! 'never)
                  (let* ((x (logic-var))
                         (m (trail-mark))
                         (ok (unify x (cons 1 x))))
                    (unwind-trail m)
                    (set-occurs-check! 'always)  ; restore default
                    (assert-true ok))))))

          ;; ── compound terms ─────────────────────────────────────────
          (make-group "compound-terms"
            (list
              (make-test "compound? is #t for (term …)"
                (lambda ()
                  (assert-true (compound? (term 'f 1 2)))))
              (make-test "compound? is #f for a list"
                (lambda ()
                  (assert-false (compound? '(f 1 2)))))
              (make-test "compound? is #f for a symbol"
                (lambda ()
                  (assert-false (compound? 'f))))
              (make-test "functor returns the functor symbol"
                (lambda ()
                  (assert-equal 'point (functor (term 'point 1 2)))))
              (make-test "arity returns argument count"
                (lambda ()
                  (assert-equal 3 (arity (term 'f 10 20 30)))))
              (make-test "arity is 0 for nullary compound"
                (lambda ()
                  (assert-equal 0 (arity (term 'nil)))))
              (make-test "arg is 1-based"
                (lambda ()
                  (let ((t (term 'f 'a 'b 'c)))
                    (assert-equal 'a (arg 1 t)))))
              (make-test "arg picks the right slot"
                (lambda ()
                  (let ((t (term 'f 'a 'b 'c)))
                    (assert-equal 'c (arg 3 t)))))
              (make-test "unify succeeds on matching functor+arity+args"
                (lambda ()
                  (let* ((m (trail-mark))
                         (ok (unify (term 'f 1 2) (term 'f 1 2))))
                    (unwind-trail m)
                    (assert-true ok))))
              (make-test "unify fails on functor mismatch"
                (lambda ()
                  (assert-false (unify (term 'f 1) (term 'g 1)))))
              (make-test "unify fails on arity mismatch"
                (lambda ()
                  (assert-false (unify (term 'f 1) (term 'f 1 2)))))
              (make-test "unify binds variables inside compound terms"
                (lambda ()
                  (let* ((x (logic-var))
                         (y (logic-var))
                         (m (trail-mark))
                         (ok (unify (term 'point x 1) (term 'point 2 y)))
                         (vx (deref-lvar x))
                         (vy (deref-lvar y)))
                    (unwind-trail m)
                    (assert-equal (list #t 2 1) (list ok vx vy)))))
              (make-test "compound vs cons do not unify"
                (lambda ()
                  (assert-false (unify (term 'f 1 2) (cons 1 (cons 2 '()))))))
              (make-test "ground? recurses into compound args"
                (lambda ()
                  (let ((x (logic-var)))
                    (assert-false (ground? (term 'f 1 x))))))
              (make-test "ground? sees bound compound as ground"
                (lambda ()
                  (let ((x (logic-var)))
                    (unify x 42)
                    (assert-true (ground? (term 'f 1 x))))))
              (make-test "copy-term preserves functor"
                (lambda ()
                  (let* ((x (logic-var))
                         (c (copy-term (term 'f x))))
                    (assert-equal 'f (functor c)))))
              (make-test "copy-term preserves arity"
                (lambda ()
                  (let* ((x (logic-var))
                         (c (copy-term (term 'f x x x))))
                    (assert-equal 3 (arity c)))))
              (make-test "copy-term freshens variables"
                (lambda ()
                  (let* ((x (logic-var))
                         (c (copy-term (term 'f x))))
                    (assert-true (logic-var? (arg 1 c))))))
              (make-test "copy-term preserves sharing"
                (lambda ()
                  (let* ((x (logic-var))
                         (c (copy-term (term 'f x x))))
                    (assert-true (eq? (arg 1 c) (arg 2 c))))))
              (make-test "occurs-check fires through compound"
                (lambda ()
                  (set-occurs-check! 'always)
                  (let* ((x (logic-var))
                         (m (trail-mark))
                         (ok (unify x (term 'f x))))
                    (unwind-trail m)
                    (assert-false ok))))
              (make-test "term rejects non-symbol functor"
                (lambda ()
                  ;; (term 42 …) should raise a type error; succeeds? treats errors as fail.
                  (assert-false
                    (succeeds? (lambda ()
                      (let ((t (term 42 1)))
                        (if t (== 1 1) (== 1 2))))))))))))

    (print-tap (run suite)))))

