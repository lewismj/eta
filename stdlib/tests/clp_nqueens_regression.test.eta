;;; clp_nqueens.eta — Regression test: N-queens correctness
;;; across small N using native diagonal propagators.  Asserts known
;;; solution counts for N = 4, 5, 6.
;;;
;;;   N | solutions
;;;   --+-----------
;;;   4 |  2
;;;   5 | 10
;;;   6 |  4

(module clp-nqueens
  (import std.core std.collections std.logic std.clp)
  (begin

    (define fail-count 0)

    (defun chk (label expected actual)
      (display label) (display " => ") (display actual)
      (if (equal? actual expected)
          (display "   [ok]")
          (begin (display "   [FAIL expected ")
                 (display expected) (display "]")
                 (set! fail-count (+ fail-count 1))))
      (newline))

    ;; Return all N-queens solutions as a list of column-assignment lists.
    (defun nqueens-all (n)
      (let loop ((i 0) (qs '()) (as '()) (bs '()))
        (cond
          ((>= i n)
           (let ((qs (reverse qs))
                 (as (reverse as))
                 (bs (reverse bs)))
             (clp:all-different qs)
             (clp:all-different as)
             (clp:all-different bs)
             (clp:labeling qs 'strategy 'ff 'solutions 'all)))
          (else
            (let* ((q  (logic-var))
                   (a  (logic-var))
                   (b  (logic-var))
                   (i1 (+ i 1)))
              (clp:domain q 1 n)
              (clp:domain a (+ 1 i1) (+ n i1))
              (clp:domain b (- 1 i1) (- n i1))
              (clp:plus-offset a q i1)
              (clp:plus-offset b q (- 0 i1))
              (loop (+ i 1) (cons q qs) (cons a as) (cons b bs)))))))

    (display "clp nqueens: start") (newline)

    (chk "nqueens(4) = 2 solutions" 2 (length (nqueens-all 4)))
    (chk "nqueens(5) = 10 solutions" 10 (length (nqueens-all 5)))
    (chk "nqueens(6) = 4 solutions" 4 (length (nqueens-all 6)))

    (newline)
    (if (= fail-count 0)
        (display "clp nqueens: ALL PASS")
        (begin (display "clp nqueens: ")
               (display fail-count) (display " FAILURE(S)")))
    (newline)))

