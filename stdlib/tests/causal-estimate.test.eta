;;; stdlib/tests/causal-estimate.test.eta -- Tests for std.causal.estimate

(module causal.estimate.tests
  (import std.test std.causal.estimate std.core std.collections)
  (begin

    (defun make-row (x z y)
      (list (cons 'x x) (cons 'z z) (cons 'y y)))

    (defun make-row-xz (x z)
      (list (cons 'x x) (cons 'z z)))

    (defun repeat-row (n row)
      (let loop ((i 0) (acc '()))
        (if (= i n)
            (reverse acc)
            (loop (+ i 1) (cons row acc)))))

    ;; Synthetic confounded sample:
    ;;   Z affects both treatment assignment and outcome.
    ;;   Structural effect of X on Y is exactly +2.
    (defun make-confounded-data ()
      (append
        ;; z=0: mostly controls
        (repeat-row 70 (make-row 0 0 0))
        (repeat-row 30 (make-row 1 0 2))
        ;; z=1: mostly treated
        (repeat-row 30 (make-row 0 1 10))
        (repeat-row 70 (make-row 1 1 12))))

    (defun mean (xs)
      (if (null? xs)
          0.0
          (/ (foldl (lambda (acc x) (+ acc x)) 0.0 xs)
             (length xs))))

    (defun treatment (obs) (cdr (assq 'x obs)))
    (defun outcome (obs)   (cdr (assq 'y obs)))
    (defun confounder (obs) (cdr (assq 'z obs)))

    (defun naive-diff (data)
      (let* ((treated (filter (lambda (o) (= (treatment o) 1)) data))
             (control (filter (lambda (o) (= (treatment o) 0)) data))
             (mu1 (mean (map* outcome treated)))
             (mu0 (mean (map* outcome control))))
        (- mu1 mu0)))

    (define data (make-confounded-data))

    (define suite
      (make-group "std.causal.estimate"
        (list
          (make-test "naive difference is confounded"
            (lambda ()
              (assert-approx-equal 6.0 (naive-diff data) 1e-12)))

          (make-test "propensity scores match z-stratified treatment rates"
            (lambda ()
              (let* ((ps (do:propensity-score data 'x '(z)))
                     (z0 (map* car
                               (filter (lambda (zp) (= (cdr zp) 0))
                                       (zip ps (map* confounder data)))))
                     (z1 (map* car
                               (filter (lambda (zp) (= (cdr zp) 1))
                                       (zip ps (map* confounder data))))))
                (assert-approx-equal 0.3 (mean z0) 1e-12)
                (assert-approx-equal 0.7 (mean z1) 1e-12))))

          (make-test "propensity scores do not require an outcome column"
            (lambda ()
              (let* ((data-xz (append
                                (repeat-row 2 (make-row-xz 0 0))
                                (repeat-row 1 (make-row-xz 1 0))
                                (repeat-row 1 (make-row-xz 0 1))
                                (repeat-row 3 (make-row-xz 1 1))))
                     (ps (do:propensity-score data-xz 'x '(z)))
                     (z0 (map* car
                               (filter (lambda (zp) (= (cdr zp) 0))
                                       (zip ps (map* confounder data-xz)))))
                     (z1 (map* car
                               (filter (lambda (zp) (= (cdr zp) 1))
                                       (zip ps (map* confounder data-xz))))))
                (assert-approx-equal (/ 1.0 3.0) (mean z0) 1e-12)
                (assert-approx-equal 0.75 (mean z1) 1e-12))))

          (make-test "g-formula recovers true ATE"
            (lambda ()
              (assert-approx-equal 2.0
                                   (do:ate-gformula data 'y 'x '(z))
                                   1e-9)))

          (make-test "IPW recovers true ATE"
            (lambda ()
              (assert-approx-equal 2.0
                                   (do:ate-ipw data 'y 'x '(z))
                                   1e-9)))

          (make-test "AIPW recovers true ATE"
            (lambda ()
              (assert-approx-equal 2.0
                                   (do:ate-aipw data 'y 'x '(z))
                                   1e-9)))

          (make-test "TMLE recovers true ATE"
            (lambda ()
              (assert-approx-equal 2.0
                                   (do:ate-tmle data 'y 'x '(z))
                                   1e-9)))

          (make-test "TMLE matches AIPW on stratified synthetic sample"
            (lambda ()
              (assert-approx-equal (do:ate-aipw data 'y 'x '(z))
                                   (do:ate-tmle data 'y 'x '(z))
                                   1e-9)))

          (make-test "bootstrap CI contains true effect"
            (lambda ()
              (let* ((ci (do:bootstrap-ci
                           (lambda (b) (do:ate-aipw b 'y 'x '(z)))
                           data
                           200
                           0.05
                           20260429))
                     (lo (car ci))
                     (hi (cdr ci)))
                (assert-true (<= lo 2.0))
                (assert-true (>= hi 2.0)))))

          (make-test "E-value for RR=2 is approximately 3.4142"
            (lambda ()
              (assert-approx-equal 3.414213562373095
                                   (do:e-value 2.0)
                                   1e-9)))

          (make-test "E-value handles protective effects by inversion"
            (lambda ()
              (assert-approx-equal 3.414213562373095
                                   (do:e-value 0.5)
                                   1e-9)))

          (make-test "Rosenbaum bound returns multiplicative sensitivity envelope"
            (lambda ()
              (let ((b (do:rosenbaum-bound 2.0 1.5)))
                (assert-approx-equal (/ 2.0 1.5) (car b) 1e-12)
                (assert-approx-equal 3.0 (cdr b) 1e-12)))))))

    (print-tap (run suite))))
