# Build artefacts and large local-only paths excluded from
# `docker build .` contexts (notably the Binder image build).

# Build outputs
out/
build/
build-*/
dist/
cmake-build-*/

# VCS
.git/
.github/

# Editor / IDE / OS
.idea/
.vs/
.vscode/
*.swp
.DS_Store

# Node / VS Code extension build
editors/vscode/node_modules/
editors/vscode/out/
editors/vscode/dist/
editors/vscode/*.vsix
**/node_modules/

# Python tooling
__pycache__/
*.py[cod]

# Compiled bytecode
*.etac

# Misc large paths
docker/jupyter/cache/

