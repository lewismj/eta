(module blackjack_demo.tests.smoke
  (import std.test std.causal.render std.io std.fs std.time std.regex std.log blackjack blackjack_demo)
  (begin

    (defun contains? (text needle)
      (regex:match? (regex:quote needle) text))

    (defun %join-with (parts sep)
      (if (null? parts)
          ""
          (let loop ((rest (cdr parts)) (acc (car parts)))
            (if (null? rest)
                acc
                (loop (cdr rest)
                      (string-append acc sep (car rest)))))))

    (defun %read-file-text (path)
      (let ((port (open-input-file path)))
        (let loop ((lines '()))
          (let ((line (read-line port)))
            (if line
                (loop (cons line lines))
                (begin
                  (close-input-port port)
                  (%join-with (reverse lines) "\n")))))))

    (defun %file-ts-stamp ()
      (let ((iso (time:format-iso8601-local (time:now-ms))))
        (string-append
          (substring iso 0 4)
          "_"
          (substring iso 5 7)
          "_"
          (substring iso 8 10)
          "_"
          (substring iso 11 13)
          "_"
          (substring iso 14 16)
          "_"
          (substring iso 17 19))))

    (define %smoke-log-path
      (string-append "smoke_test_" (%file-ts-stamp) ".log"))

    (defun %format-ts (ms)
      (let ((iso (time:format-iso8601-local ms)))
        (string-append
          (substring iso 8 10)
          "-"
          (substring iso 5 7)
          "-"
          (substring iso 2 4)
          "-"
          (substring iso 11 13)
          "-"
          (substring iso 14 16)
          "-"
          (substring iso 17 19))))

    (defun %log-line (message)
      (let ((now (time:now-ms)))
        (let* ((sink (log:make-file-sink %smoke-log-path))
               (logger (log:make-logger
                         (string-append "blackjack.demo.tests.smoke."
                                        (number->string now))
                         (list sink))))
          (log:set-pattern! logger "%v")
          (log:flush-on! logger 'info)
          (log:info logger
                    (string-append
                      "["
                      (%format-ts now)
                      "] "
                      message))
          (log:flush! logger))))

    (defun %timed (label thunk)
      (%log-line (string-append "start=" label))
      (let* ((t0 (time:monotonic-ms))
             (out (thunk))
             (t1 (time:monotonic-ms))
             (elapsed (time:elapsed-ms t0 t1)))
        (%log-line (string-append "end=" label
                                  ", elapsed-ms="
                                  (number->string elapsed)))
        out))

    (defun %make-logged-test (name thunk)
      (make-test name
        (lambda ()
          (%timed (string-append "test=" name)
                  thunk))))

    (defun %argv->string (argv)
      (%join-with argv " "))

    (defun %strip-app-log (argv)
      (let loop ((rest argv) (acc '()))
        (if (null? rest)
            (reverse acc)
            (if (string=? (car rest) "--app-log")
                (if (null? (cdr rest))
                    (reverse acc)
                    (loop (cdr (cdr rest)) acc))
                (loop (cdr rest)
                      (cons (car rest) acc))))))

    (defun %argv-with-smoke-log (argv)
      (append (%strip-app-log argv)
              (list "--app-log" %smoke-log-path)))

    (defun %run-command-logged (label argv)
      (%timed (string-append "run-command=" label)
              (lambda ()
                (let ((argv2 (%argv-with-smoke-log argv)))
                  (%log-line (string-append "argv=" (%argv->string argv2)))
                  (run-command argv2)))))

    (defun %extract-app-log-path (text)
      (let* ((needle "app-log=")
             (n (string-length text))
             (m (string-length needle)))
        (let find ((i 0))
          (if (> i (- n m))
              ""
              (if (string=? (substring text i (+ i m)) needle)
                  (let read ((j (+ i m)))
                    (if (or (= j n)
                            (eq? (string-ref text j) #\newline)
                            (eq? (string-ref text j) #\return))
                        (substring text (+ i m) j)
                        (read (+ j 1))))
                  (find (+ i 1)))))))

    (define suite
      (make-group "blackjack_demo"
        (list
          (%make-logged-test "blackjack-dependency"
            (lambda ()
              (assert-equal "Blackjack demo scaffold ready."
                            (scaffold-message))))
          (%make-logged-test "b1-rules-export-through-package"
            (lambda ()
              (assert-true (blackjack '(1 13)))))
          (%make-logged-test "b2-mc-export-through-package"
            (lambda ()
              (let* ((cfg (make-mc-shoe 5))
                     (rows (simulate policy-hit-below-17 cfg 4 1)))
                (assert-equal 4 (length rows)))))
          (%make-logged-test "b4-causal-export-through-package"
            (lambda ()
              (assert-equal 2
                            (find-flip-threshold
                              state-16-vs-10
                              default-count-buckets))))
          (%make-logged-test "b4-causal-dag-renders-through-stdlib"
            (lambda ()
              (let ((dot (dag:->dot blackjack-causal-dag
                                    '((title . "blackjack")))))
                (assert-true (contains? dot "digraph \"blackjack\""))
                (assert-true (contains? dot "\"state\" -> \"action\""))
                (assert-true (contains? dot "\"action\" -> \"outcome\"")))))
          (%make-logged-test "b5-learn-export-through-package"
            (lambda ()
              (let* ((cfg (make-learn-config learn-mode-supervised
                                             7
                                             4
                                             16
                                             0.01
                                             2))
                     (result (recover-hi-lo cfg)))
                (assert-true (learn-result? result))
                (assert-equal learn-mode-supervised
                              (learn-result-mode result)))))
          (%make-logged-test "b6-strategy-export-through-package"
            (lambda ()
              (let ((snapshot (render-strategy-chart 0)))
                (assert-true (contains? snapshot "count=0"))
                (assert-true (contains? snapshot "dealer,2,3,4,5,6,7,8,9,10,A")))))
          (%make-logged-test "b6.5-maxims-export-through-package"
            (lambda ()
              (let ((rules (render-maxim-clauses-for-count 0)))
                (assert-true (contains? rules "count=0"))
                (assert-true (contains? rules "total-in(17,20)"))
                (assert-true (contains? rules "default -> hit")))))
          (%make-logged-test "b6-app-prints-multi-bucket-chart"
            (lambda ()
              (let ((out (chart-output)))
                (assert-true (contains? out "count=-2"))
                (assert-true (contains? out "count=0"))
                (assert-true (contains? out "count=2")))))
          (%make-logged-test "b7-help-documents-subcommands-config-and-seed"
            (lambda ()
              (let ((help (cli-help)))
                (assert-true (contains? help "subcommands:"))
                (assert-true (contains? help "all"))
                (assert-true (contains? help "report"))
                (assert-true (contains? help "--config"))
                (assert-true (contains? help "--seed"))
                (assert-true (contains? help "--workers"))
                (assert-true (contains? help "--app-log"))
                (assert-true (contains? help "app_log_path"))
                (assert-true (contains? help "induce_workers")))))
          (%make-logged-test "b7-chart-subcommand-renders-section-output"
            (lambda ()
              (let ((out (%run-command-logged
                           "chart"
                           '("chart" "--seed" "42" "--app-log" "off"))))
                (assert-true (contains? out "== chart =="))
                (assert-true (contains? out "elapsed-ms="))
                (assert-true (contains? out "seed=42"))
                (assert-true (contains? out "count=-2"))
                (assert-true (contains? out "count=0"))
                (assert-true (contains? out "count=2")))))
          (%make-logged-test "b7-json-config-controls-learn-settings"
            (lambda ()
              (let ((out (%run-command-logged
                           "learn-supervised-demo-config"
                           '("learn" "--config" "tests/config/supervised_demo.json"
                             "--app-log" "off"))))
                (assert-true (contains? out "== learn =="))
                (assert-true (contains? out "elapsed-ms="))
                (assert-true (contains? out "mode=supervised"))
                (assert-true (contains? out "requested-seed=42"))
                (assert-true (contains? out "epochs=12"))
                (assert-true (contains? out "learning-rate=0.01"))
                (assert-true (contains? out "policy-refresh=8")))))
          (%make-logged-test "b7-all-subcommand-produces-documented-sections"
            (lambda ()
              (let ((out (%run-command-logged
                           "all-supervised-demo-config"
                           '("all" "--config" "tests/config/supervised_demo.json"
                             "--app-log" "smoke.test.log"))))
                (assert-true (contains? out "Blackjack demo scaffold ready."))
                (assert-true (contains? out "== induce =="))
                (assert-true (contains? out "== causal =="))
                (assert-true (contains? out "== learn =="))
                (assert-true (contains? out "== chart =="))
                (assert-true (contains? out "== maxims =="))
                (assert-true (contains? out "== report =="))
                (assert-true (contains? out "total-elapsed-ms="))
                (assert-true (contains? out "seed=42")))))
          (%make-logged-test "b7-report-subcommand-includes-bottleneck-summary"
            (lambda ()
              (let ((out (%run-command-logged
                           "report-supervised-demo-config"
                           '("report" "--config" "tests/config/supervised_demo.json"
                             "--app-log" "smoke.test.log"))))
                (assert-true (contains? out "== report =="))
                (assert-true (contains? out "slowest-phases:"))
                (assert-true (contains? out "total-elapsed-ms=")))))
          (%make-logged-test "b7-single-smoke-log-path-is-used"
            (lambda ()
              (let* ((out (%run-command-logged
                            "induce-auto-app-log"
                            '("induce" "--config" "tests/config/supervised_demo.json"
                              "--app-log" "auto")))
                     (path (%extract-app-log-path out)))
                (assert-equal %smoke-log-path path)
                (assert-true (fs:file-exists? path)))))
          (%make-logged-test "b7-all-subcommand-persists-timing-log"
            (lambda ()
              (let ((out (%run-command-logged
                           "all-explicit-app-log"
                           (list "all"
                                 "--config" "tests/config/supervised_demo.json"
                                 "--app-log" "off"))))
                  (assert-true (contains? out "total-elapsed-ms="))
                  (assert-true (contains? out (string-append "app-log=" %smoke-log-path)))
                  (assert-true (fs:file-exists? %smoke-log-path))
                  (let ((log-text (%read-file-text %smoke-log-path)))
                    (assert-true (contains? log-text "command-start=all"))
                    (assert-true (contains? log-text "phase-start=maxims"))
                    (assert-true (contains? log-text "phase-end=maxims"))
                    (assert-true (contains? log-text "command-complete=all"))
                    (assert-true (contains? log-text "elapsed-ms="))
                    (assert-true (contains? log-text "total-elapsed-ms="))
                    (assert-true (contains? log-text "induce-worker-profile"))
                    (assert-true (contains? log-text "learn-training-output-path="))
                    (assert-true (contains? log-text "report-summary="))))))
          (%make-logged-test "b7-unknown-subcommand-returns-runtime-error"
            (lambda ()
              (let ((err (catch 'runtime.error
                           (%run-command-logged "unknown-subcommand" '("unknown")))))
                (assert-equal 'runtime-error (car err))))))))
    (begin
      (let* ((sink (log:make-file-sink %smoke-log-path 'truncate? #t))
             (logger (log:make-logger "blackjack.demo.tests.smoke.init" (list sink))))
        (log:set-pattern! logger "%v")
        (log:flush-on! logger 'info)
        (log:flush! logger))
      (%log-line (string-append "suite-start path=" %smoke-log-path)))
    (let ((result (run suite)))
      (%log-line "suite-end")
      (print-tap result))))
