(module blackjack.tests.causal
  (import std.test std.causal blackjack)
  (begin

    (defun alist-get (key rows)
      (let ((pair (assoc key rows)))
        (if pair (cdr pair) #f)))

    (define suite
      (make-group "blackjack causal"
        (list
          (make-test "causal dag identifies an adjustment estimand"
            (lambda ()
              (assert-true (dag:valid? blackjack-causal-dag))
              (assert-equal 'adjust
                            (alist-get 'status causal-identification-details))
              (assert-true causal-identification-formula)))

          (make-test "ev-obs and ev-do diverge under biased behaviour policy"
            (lambda ()
              (let* ((obs (ev-obs state-16-vs-10 'stand 2))
                     (do-val (ev-do state-16-vs-10 'stand 2)))
                (assert-true (> (abs (- obs do-val)) 0.03)))))

          (make-test "16 vs 10 flips from hit to stand at high count under do()"
            (lambda ()
              (assert-equal 'hit (policy-do state-16-vs-10 -2))
              (assert-equal 'stand (policy-do state-16-vs-10 2))
              (assert-equal 2
                            (find-flip-threshold
                              state-16-vs-10
                              default-count-buckets)))))))

    (print-tap (run suite))))
