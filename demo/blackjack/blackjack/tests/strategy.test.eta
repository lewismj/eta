(module blackjack.tests.strategy
  (import std.test blackjack)
  (begin

    (define %count0-snapshot
      (string-append
        "count=0\n"
        "dealer,2,3,4,5,6,7,8,9,10,A\n"
        "20,S,S,S,S,S,S,S,S,S,S\n"
        "19,S,S,S,S,S,S,S,S,S,S\n"
        "18,S,S,S,S,S,S,S,S,S,S\n"
        "17,S,S,S,S,S,S,S,S,S,S\n"
        "16,S,S,S,S,S,H,H,H,H,H\n"
        "15,S,S,S,S,S,H,H,H,H,H\n"
        "14,S,S,S,S,S,H,H,H,H,H\n"
        "13,S,S,S,S,S,H,H,H,H,H\n"
        "12,H,H,S,S,S,H,H,H,H,H\n"
        "11,H,H,H,H,H,H,H,H,H,H\n"
        "10,H,H,H,H,H,H,H,H,H,H\n"
        "9,H,H,H,H,H,H,H,H,H,H\n"
        "8,H,H,H,H,H,H,H,H,H,H\n"
        "7,H,H,H,H,H,H,H,H,H,H\n"
        "6,H,H,H,H,H,H,H,H,H,H\n"
        "5,H,H,H,H,H,H,H,H,H,H"))

    (define suite
      (make-group "blackjack strategy"
        (list
          (make-test "clp enumeration covers full grid for one bucket"
            (lambda ()
              (let* ((cells (enumerate-strategy-cells '(0)))
                     (expected (* (length chart-player-totals)
                                  (length chart-dealer-ups))))
                (assert-equal expected (length cells)))))

          (make-test "count 0 snapshot is deterministic and stable"
            (lambda ()
              (let* ((snapshot-a (render-strategy-chart 0))
                     (snapshot-b (render-strategy-chart 0)))
                (assert-equal snapshot-a snapshot-b)
                (assert-equal %count0-snapshot snapshot-a))))

          (make-test "high-count deviation flips 16 vs 10 from hit to stand"
            (lambda ()
              (let* ((cells (enumerate-strategy-cells '(0 2))))
                (assert-equal 'hit (chart-action-at cells 16 10 0))
                (assert-equal 'stand (chart-action-at cells 16 10 2))))))))

    (print-tap (run suite))))
