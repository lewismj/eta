;;; test_ror.eta — Minimal reverse-on-reverse test
(module test_ror
  (import std.core)
  (import std.io)
  (begin

    ;; ── Native Dual AD primitives ──────────────────────────────────
    (defun nd-val (x) (if (dual? x) (dual-primal x) x))
    (defun nd-bp  (x) (if (dual? x) (dual-backprop x) (lambda (adj) '())))
    (defun nd-make-var (v idx) (make-dual v (lambda (adj) (list (cons idx adj)))))
    (defun nd-ensure (x) (if (dual? x) x (make-dual x (lambda (adj) '()))))

    ;; ── Lifted arithmetic ──────────────────────────────────────────
    (defun nd* (a b)
      (let ((a (nd-ensure a)) (b (nd-ensure b)))
        (let ((va (nd-val a)) (vb (nd-val b))
              (ba (nd-bp a))  (bb (nd-bp b)))
          (make-dual (* va vb)
                     (lambda (adj) (append (ba (* adj vb)) (bb (* adj va))))))))

    (defun nd+ (a b)
      (let ((a (nd-ensure a)) (b (nd-ensure b)))
        (let ((va (nd-val a)) (vb (nd-val b))
              (ba (nd-bp a))  (bb (nd-bp b)))
          (make-dual (+ va vb)
                     (lambda (adj) (append (ba adj) (bb adj)))))))

    ;; ── Gradient driver ────────────────────────────────────────────
    (defun collect-adjoints (n adj-list)
      (let ((result (make-vector n 0)))
        (letrec ((loop (lambda (xs)
                         (if (null? xs)
                             result
                             (let ((p (car xs)))
                               (let ((i (car p))
                                     (v (cdr p)))
                                 (vector-set! result i
                                   (+ (vector-ref result i) v))
                                 (loop (cdr xs))))))))
          (loop adj-list))))

    (defun native-grad (f vals)
      (letrec ((make-vars
                 (lambda (vs idx)
                   (if (null? vs) '()
                       (cons (nd-make-var (car vs) idx)
                             (make-vars (cdr vs) (+ idx 1)))))))
        (let ((duals (make-vars vals 0)))
          (let ((out (apply f duals)))
            (let ((primal (nd-val out))
                  (adjoints ((nd-bp out) 1)))
              (list primal (collect-adjoints (length vals) adjoints)))))))

    ;; ── Test 1: f(x) = x*x, f'(x)=2x, f''(x)=2 ──────────────────
    (display "Test 1: f(x) = x*x at x=3\n")
    (let ((r (native-grad (lambda (x) (nd* x x)) '(3.0))))
      (display "  f(3)  = ") (println (car r))
      (display "  f'(3) = ") (println (vector-ref (cadr r) 0)))

    ;; ── Test 2: Reverse-on-reverse for f''(x) ─────────────────────
    (display "\nTest 2: f''(x) = 2 via reverse-on-reverse\n")
    (let ((x-dual (make-dual 3.0 (lambda (adj) (list (cons 0 adj))))))
      (let ((result (native-grad (lambda (x) (nd* x x)) (list x-dual))))
        (let ((grad-x (vector-ref (cadr result) 0)))
          (display "  f'(3) as Dual: ") (println grad-x)
          (display "  dual? = ") (println (dual? grad-x))
          (if (dual? grad-x)
              (begin
                (display "  f'(3) primal = ") (println (dual-primal grad-x))
                (let ((second-order ((dual-backprop grad-x) 1)))
                  (display "  second-order adjoints = ") (println second-order)
                  (if (null? second-order)
                      (display "  (empty - no 2nd deriv captured)\n")
                      (let ((h (collect-adjoints 1 second-order)))
                        (display "  f''(3) = ")
                        (println (vector-ref h 0))))))
              (display "  (not a dual - 2nd deriv not available)\n")))))

    (display "\nDone.\n")
  ))

