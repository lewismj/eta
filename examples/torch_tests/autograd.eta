;;; torch_tests/autograd.eta — Autograd primitives
;;;
;;; Tests: requires-grad!, requires-grad?, backward, grad, zero-grad!, detach
;;;
;;; Run:  etai examples/torch_tests/autograd.eta

(module torch-test-autograd
  (import std.core)
  (import std.io)
  (import std.torch)
  (import std.test)
  (begin

    (define results
      (run (make-group "Autograd"
        (list

          ;; ── dy/dx = 2x at x=3 → 6 ────────────────────────────────
          (make-test "x^2 gradient"
            (lambda ()
              (let* ((x (from-list '(3.0))))
                (requires-grad! x #t)
                (let ((y (t* x x)))
                  (backward y)
                  (assert-equal 6.0 (item (grad x))
                    "dy/dx of x^2 at x=3 should be 6")))))

          ;; ── exp gradient ──────────────────────────────────────────
          (make-test "exp gradient"
            (lambda ()
              (let* ((x (from-list '(0.0))))
                (requires-grad! x #t)
                (backward (texp x))
                (assert-equal 1.0 (item (grad x))
                  "d/dx exp(x) at x=0 should be 1"))))

          ;; ── multivariate: f(x,y) = x*y ───────────────────────────
          (make-test "multivariate gradient"
            (lambda ()
              (let ((x (from-list '(2.0)))
                    (y (from-list '(3.0))))
                (requires-grad! x #t)
                (requires-grad! y #t)
                (backward (t* x y))
                (assert-equal 3.0 (item (grad x)) "df/dx = y = 3")
                (assert-equal 2.0 (item (grad y)) "df/dy = x = 2"))))

          ;; ── requires-grad? predicate ──────────────────────────────
          (make-test "requires-grad? predicate"
            (lambda ()
              (let ((x (tensor 1.0)))
                (assert-false (requires-grad? x) "initially false")
                (requires-grad! x #t)
                (assert-true (requires-grad? x) "after setting true"))))

          ;; ── zero-grad! ────────────────────────────────────────────
          (make-test "zero-grad!"
            (lambda ()
              (let ((x (from-list '(4.0))))
                (requires-grad! x #t)
                (backward (t* x x))
                ;; grad should be 8
                (assert-equal 8.0 (item (grad x)))
                ;; zero it
                (zero-grad! x)
                (assert-equal 0.0 (item (grad x))
                  "grad should be zero after zero-grad!"))))

          ;; ── detach ────────────────────────────────────────────────
          (make-test "detach"
            (lambda ()
              (let ((x (tensor 5.0)))
                (requires-grad! x #t)
                (let ((d (detach x)))
                  (assert-false (requires-grad? d)
                    "detached tensor should not require grad")))))

        ))))

    (print-summary (summary results))
    (assert-equal 0 (summary-failed (summary results)) "autograd tests failed")
  ))

