;;; torch_tests/nn_layers.eta — Neural network layer primitives
;;;
;;; Tests: linear, sequential, relu-layer, sigmoid-layer, dropout,
;;;        forward, parameters, module?, train!, eval!
;;;
;;; This is the critical test file — nn/sequential via the Eta binding path
;;; is exactly the code path where the sequential bug was found.
;;;
;;; Run:  etai examples/torch_tests/nn_layers.eta

(module torch-test-nn-layers
  (import std.core)
  (import std.io)
  (import std.torch)
  (import std.test)
  (begin

    (define results
      (run (make-group "NN Layers"
        (list

          ;; ── nn/linear ─────────────────────────────────────────────
          (make-test "linear creation"
            (lambda ()
              (let ((l (linear 4 2)))
                (assert-true (module? l) "linear is module")
                ;; weight + bias = 2 parameter tensors
                (assert-equal 2 (length (parameters l))
                  "linear has 2 params"))))

          (make-test "linear forward shape"
            (lambda ()
              (let* ((l   (linear 4 2))
                     (inp (randn '(1 4)))
                     (out (forward l inp)))
                (assert-equal '(1 2) (shape out)))))

          (make-test "linear batch forward"
            (lambda ()
              (let* ((l   (linear 3 5))
                     (inp (randn '(8 3)))
                     (out (forward l inp)))
                (assert-equal '(8 5) (shape out)))))

          ;; ── nn/sequential (3-layer: the causal_demo pattern) ──────
          (make-test "sequential 3-layer"
            (lambda ()
              (let* ((net (sequential (linear 4 8)
                                      (relu-layer)
                                      (linear 8 2)))
                     (inp (randn '(1 4)))
                     (out (forward net inp)))
                (assert-true  (module? net) "sequential is module")
                (assert-equal '(1 2) (shape out) "sequential output shape"))))

          ;; ── nn/sequential (single layer) ──────────────────────────
          (make-test "sequential single layer"
            (lambda ()
              (let* ((net (sequential (linear 3 2)))
                     (out (forward net (randn '(1 3)))))
                (assert-equal '(1 2) (shape out)))))

          ;; ── nn/sequential (deep 5-layer like causal_demo) ─────────
          (make-test "sequential deep network"
            (lambda ()
              (let* ((net (sequential (linear 2 32)
                                      (relu-layer)
                                      (linear 32 16)
                                      (relu-layer)
                                      (linear 16 1)))
                     (inp (randn '(5 2)))
                     (out (forward net inp)))
                (assert-equal '(5 1) (shape out) "deep net output shape")
                ;; 3 linears × (weight + bias) = 6 parameter tensors
                (assert-equal 6 (length (parameters net))
                  "deep net parameter count"))))

          ;; ── nn/sequential with sigmoid ────────────────────────────
          (make-test "sequential with sigmoid"
            (lambda ()
              (let* ((net (sequential (linear 4 2)
                                      (sigmoid-layer)))
                     (out (forward net (randn '(1 4)))))
                (assert-equal '(1 2) (shape out))
                ;; sigmoid output in (0, 1)
                (assert-true (> (item (tmin out)) 0.0) "sigmoid > 0")
                (assert-true (< (item (tmax out)) 1.0) "sigmoid < 1"))))

          ;; ── nn/sequential with dropout ────────────────────────────
          (make-test "sequential with dropout"
            (lambda ()
              (let* ((net (sequential (linear 4 4)
                                      (dropout 0.5)
                                      (linear 4 1)))
                     (out (forward net (randn '(1 4)))))
                (assert-equal '(1 1) (shape out) "dropout net output shape")
                ;; parameters: 2 linear layers = 4 params (dropout has none)
                (assert-equal 4 (length (parameters net))
                  "dropout net param count"))))

          ;; ── module? predicate ─────────────────────────────────────
          (make-test "module? predicate"
            (lambda ()
              (assert-true  (module? (linear 2 1)) "linear is module")
              (assert-false (module? 42)           "fixnum is not module")
              (assert-false (module? (ones '(2)))   "tensor is not module")))

          ;; ── train! / eval! ────────────────────────────────────────
          (make-test "train! and eval! return module"
            (lambda ()
              (let ((l (linear 2 1)))
                (assert-true (module? (train! l)) "train! returns module")
                (assert-true (module? (eval! l))  "eval! returns module"))))

        ))))

    (print-summary (summary results))
    (assert-equal 0 (summary-failed (summary results)) "nn layer tests failed")
  ))

