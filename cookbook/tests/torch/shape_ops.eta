;;; tests/torch/shape_ops.eta — Shape manipulation primitives
;;;
;;; Tests: shape, reshape, transpose, squeeze, unsqueeze, cat, numel
;;;
;;; Run:  etai cookbook/tests/torch/shape_ops.eta

(module torch-test-shape-ops
  (import std.core)
  (import std.io)
  (import std.torch)
  (import std.test)
  (begin

    (define results
      (run (make-group "Shape Ops"
        (list

          (make-test "shape query"
            (lambda ()
              (assert-equal '(2 3) (shape (ones '(2 3))))))

          (make-test "reshape"
            (lambda ()
              (let* ((t (ones '(2 3)))       ;; 6 elements
                     (r (reshape t '(3 2))))
                (assert-equal '(3 2) (shape r))
                (assert-equal 6 (numel r)))))

          (make-test "transpose"
            (lambda ()
              (let* ((t (ones '(2 3)))
                     (r (transpose t 0 1)))
                (assert-equal '(3 2) (shape r)))))

          (make-test "unsqueeze and squeeze"
            (lambda ()
              (let* ((t  (ones '(2 3)))
                     (u  (unsqueeze t 0))       ;; → (1 2 3)
                     (s  (squeeze u)))           ;; → (2 3)
                (assert-equal '(1 2 3) (shape u) "unsqueeze")
                (assert-equal '(2 3)   (shape s) "squeeze"))))

          (make-test "cat along dim 0"
            (lambda ()
              (let* ((a (ones '(2 3)))
                     (b (zeros '(2 3)))
                     (c (cat (list a b) 0)))
                (assert-equal '(4 3) (shape c) "cat shape")
                ;; sum: 2*3 ones + 2*3 zeros = 6
                (assert-equal 6.0 (item (tsum c)) "cat sum"))))

          (make-test "cat along dim 1"
            (lambda ()
              (let* ((a (ones  '(2 3)))
                     (b (zeros '(2 4)))
                     (c (cat (list a b) 1)))
                (assert-equal '(2 7) (shape c)))))

          (make-test "numel"
            (lambda ()
              (assert-equal 24 (numel (ones '(2 3 4))))))

        ))))

    (print-summary (summary results))
    (assert-equal 0 (summary-failed (summary results)) "shape ops tests failed")
  ))

