;;; tests/torch/optimizers.eta — Optimizer primitives
;;;
;;; Tests: sgd, adam, step!, optim-zero-grad!, optimizer?
;;;
;;; Run:  etai cookbook/tests/torch/optimizers.eta

(module torch-test-optimizers
  (import std.core)
  (import std.io)
  (import std.torch)
  (import std.test)
  (begin

    (define results
      (run (make-group "Optimizers"
        (list

          ;; ── SGD creation ──────────────────────────────────────────
          (make-test "sgd creation"
            (lambda ()
              (let* ((m (linear 2 1))
                     (o (sgd m 0.01)))
                (assert-true (optimizer? o) "sgd is optimizer")
                (assert-false (optimizer? m) "module is not optimizer")
                (assert-false (optimizer? 42) "fixnum is not optimizer"))))

          ;; ── Adam creation ─────────────────────────────────────────
          (make-test "adam creation"
            (lambda ()
              (let* ((m (linear 3 1))
                     (o (adam m 0.001)))
                (assert-true (optimizer? o) "adam is optimizer"))))

          ;; ── SGD step changes weights ──────────────────────────────
          (make-test "sgd step changes weights"
            (lambda ()
              (let* ((m   (linear 2 1))
                     (opt (sgd m 0.1))
                     (inp (from-list '(1.0 2.0)))
                     (inp (reshape inp '(1 2)))
                     (tgt (from-list '(5.0)))
                     (tgt (reshape tgt '(1 1))))
                ;; Capture initial prediction
                (let* ((pred0  (forward m inp))
                       (loss0  (mse-loss pred0 tgt)))
                  ;; Do one training step
                  (optim-zero-grad! opt)
                  (let* ((pred (forward m inp))
                         (loss (mse-loss pred tgt)))
                    (backward loss)
                    (step! opt)
                    ;; After step, a new forward should give different output
                    (let ((pred1 (forward m inp)))
                      (assert-true
                        (not (= (item pred0) (item pred1)))
                        "weights should change after SGD step")))))))

          ;; ── Adam step changes weights ─────────────────────────────
          (make-test "adam step changes weights"
            (lambda ()
              (let* ((m   (linear 2 1))
                     (opt (adam m 0.01))
                     (inp (reshape (from-list '(1.0 2.0)) '(1 2)))
                     (tgt (reshape (from-list '(5.0)) '(1 1)))
                     (pred0 (forward m inp)))
                (optim-zero-grad! opt)
                (let ((loss (mse-loss (forward m inp) tgt)))
                  (backward loss)
                  (step! opt)
                  (let ((pred1 (forward m inp)))
                    (assert-true
                      (not (= (item pred0) (item pred1)))
                      "weights should change after Adam step"))))))

        ))))

    (print-summary (summary results))
    (assert-equal 0 (summary-failed (summary results)) "optimizer tests failed")
  ))

