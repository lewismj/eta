(module parent-test)
(define sock (nng-socket 'pair))
(nng-listen sock "ipc:///tmp/eta_diag_test.sock")
(display "parent: listening")
(newline)
(send! sock 41 'wait)
(display "parent: sent 41, waiting for reply...")
(newline)
(define result (recv! sock 'wait))
(display "parent: received: ")
(display result)
(newline)
(nng-close sock)

