(module test-set2
  (begin
    ;; Does set! work on let-bound var in same scope (not closure)?
    (let ((x 1))
      (set! x 2)
      (display "same-scope set! result: ") (display x) (newline))

    ;; Does vector-set! work across closures?
    (let ((box (make-vector 1 #f)))
      (define setter (lambda () (vector-set! box 0 42)))
      (define getter (lambda () (vector-ref box 0)))
      (setter)
      (display "vector-set! across closures: ") (display (getter)) (newline))

    ;; Does dynamic-wind + vector-set! work?
    (let ((box (make-vector 1 #f)))
      (dynamic-wind
        (lambda () (vector-set! box 0 99))
        (lambda ()
          (display "dynamic-wind body via vector: ")
          (display (vector-ref box 0))
          (newline))
        (lambda ()
          (display "dynamic-wind after via vector: ")
          (display (vector-ref box 0))
          (newline))))))

