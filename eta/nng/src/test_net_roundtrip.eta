(module test-net-roundtrip
  (import std.net)
  (begin

    ;; Round-trip test via inproc PAIR sockets using with-socket
    (define server (nng-socket 'pair))
    (nng-listen server "inproc://net-roundtrip-test")

    (define reply
      (with-socket 'pair
        (lambda (client)
          (nng-dial client "inproc://net-roundtrip-test")
          (send! client '(hello world))
          ;; Server receives and echoes
          (let ((msg (recv! server 'wait)))
            (send! server msg 'wait))
          ;; Client receives the echo
          (recv! client 'wait))))

    (nng-close server)

    (display "round-trip result: ")
    (display reply)
    (newline)

    ;; Verify the result is the original message
    (display "round-trip correct?: ")
    (display (equal? reply '(hello world)))
    (newline)

    (display "Phase 5 round-trip test passed.")
    (newline)))

