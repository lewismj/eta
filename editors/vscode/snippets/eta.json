{
    "Module": {
        "prefix": "module",
        "body": [
            "(module ${1:name}",
            "  (import ${2:std.prelude})",
            "  (export ${3:})",
            "  (begin",
            "    $0))"
        ],
        "description": "Module skeleton with import and begin"
    },
    "Function Definition": {
        "prefix": "defun",
        "body": [
            "(defun ${1:name} (${2:args})",
            "  $0)"
        ],
        "description": "Define a named function"
    },
    "Variable Definition": {
        "prefix": "define",
        "body": "(define ${1:name} ${0:value})",
        "description": "Define a variable"
    },
    "Lambda": {
        "prefix": "lambda",
        "body": [
            "(lambda (${1:args})",
            "  $0)"
        ],
        "description": "Anonymous function"
    },
    "Let": {
        "prefix": "let",
        "body": [
            "(let ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Parallel local bindings"
    },
    "Let*": {
        "prefix": "let*",
        "body": [
            "(let* ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Sequential local bindings"
    },
    "Letrec": {
        "prefix": "letrec",
        "body": [
            "(letrec ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Recursive local bindings"
    },
    "If": {
        "prefix": "if",
        "body": "(if ${1:test}\n    ${2:consequent}\n    ${0:alternate})",
        "description": "Conditional expression"
    },
    "Cond": {
        "prefix": "cond",
        "body": [
            "(cond",
            "  (${1:test} ${2:expr})",
            "  (else ${0:default}))"
        ],
        "description": "Multi-way conditional"
    },
    "Case": {
        "prefix": "case",
        "body": [
            "(case ${1:key}",
            "  ((${2:datum}) ${3:expr})",
            "  (else ${0:default}))"
        ],
        "description": "Dispatch on datum equality"
    },
    "When": {
        "prefix": "when",
        "body": [
            "(when ${1:test}",
            "  $0)"
        ],
        "description": "One-armed conditional (when test is true)"
    },
    "Unless": {
        "prefix": "unless",
        "body": [
            "(unless ${1:test}",
            "  $0)"
        ],
        "description": "One-armed conditional (when test is false)"
    },
    "Define Record Type": {
        "prefix": "define-record-type",
        "body": [
            "(define-record-type ${1:name}",
            "  (${2:make-name} ${3:field1})",
            "  ${4:name?}",
            "  (${3:field1} ${5:name-field1}))"
        ],
        "description": "Record type definition"
    },
    "Import": {
        "prefix": "import",
        "body": "(import ${1:module-name})",
        "description": "Import bindings from a module"
    },
    "Catch": {
        "prefix": "catch",
        "body": [
            "(catch '${1:tag}",
            "  $0)"
        ],
        "description": "Catch exceptions with a tag"
    },
    "Raise": {
        "prefix": "raise",
        "body": "(raise '${1:tag} ${0:value})",
        "description": "Raise an exception with a tag"
    },
    "Define Syntax": {
        "prefix": "define-syntax",
        "body": [
            "(define-syntax ${1:name}",
            "  (syntax-rules ()",
            "    ((${1:name} ${2:pattern})",
            "     ${0:template})))"
        ],
        "description": "Define a hygienic macro"
    },
    "Do": {
        "prefix": "do",
        "body": [
            "(do ((${1:var} ${2:init} ${3:step}))",
            "    ((${4:test}) ${5:result})",
            "  $0)"
        ],
        "description": "Iteration construct"
    },

    "Import Net": {
        "prefix": "import-net",
        "body": "(import std.net)",
        "description": "Import the networking / message-passing module"
    },
    "NNG Socket": {
        "prefix": "nng-socket",
        "body": [
            "(define ${1:sock} (nng-socket '${2|pair,pub,sub,push,pull,req,rep,surveyor,respondent,bus|}))",
            "(nng-${3|listen,dial|} ${1:sock} \"${4:tcp://localhost:5555}\")",
            "$0"
        ],
        "description": "Create and listen/dial an nng socket"
    },
    "With Socket": {
        "prefix": "with-socket",
        "body": [
            "(with-socket '${1|pair,req,rep,pub,sub,push,pull,surveyor,respondent,bus|}",
            "  (lambda (${2:sock})",
            "    (nng-dial ${2:sock} \"${3:tcp://localhost:5555}\")",
            "    $0))"
        ],
        "description": "Safe socket with automatic dynamic-wind cleanup"
    },
    "Spawn Worker": {
        "prefix": "spawn",
        "body": [
            "(define ${1:worker} (spawn \"${2:worker.eta}\"))",
            "(send! ${1:worker} ${3:'(task)})",
            "(define ${4:result} (recv! ${1:worker} 'wait))",
            "(spawn-wait ${1:worker})",
            "(nng-close ${1:worker})",
            "$0"
        ],
        "description": "Spawn a child process, send a message, receive the result, and clean up"
    },
    "Send/Recv": {
        "prefix": "send-recv",
        "body": [
            "(send! ${1:sock} ${2:value})",
            "(define ${3:reply} (recv! ${1:sock} 'wait))",
            "$0"
        ],
        "description": "Send a message and wait for a reply"
    },
    "Worker Pool": {
        "prefix": "worker-pool",
        "body": [
            "(define ${1:results} (worker-pool \"${2:worker.eta}\" ${3:tasks}))",
            "$0"
        ],
        "description": "Distribute tasks across a pool of worker processes and collect results"
    },
    "Request Reply": {
        "prefix": "request-reply",
        "body": [
            "(define ${1:result} (request-reply \"${2:tcp://localhost:5555}\" ${3:message}))",
            "$0"
        ],
        "description": "Synchronous one-shot request-reply over a REQ socket"
    },
    "Current Mailbox": {
        "prefix": "current-mailbox",
        "body": [
            "(define ${1:mailbox} (current-mailbox))",
            "(define ${2:msg} (recv! ${1:mailbox} 'wait))",
            "$0"
        ],
        "description": "Receive the parent socket inside a spawned child process"
    }
}

