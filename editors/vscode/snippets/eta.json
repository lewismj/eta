{
    "Module": {
        "prefix": "module",
        "body": [
            "(module ${1:name}",
            "  (import ${2:std.prelude})",
            "  (export ${3:})",
            "  (begin",
            "    $0))"
        ],
        "description": "Module skeleton with import, export, and begin"
    },
    "Function Definition": {
        "prefix": "defun",
        "body": [
            "(defun ${1:name} (${2:args})",
            "  $0)"
        ],
        "description": "Define a named function"
    },
    "Variable Definition": {
        "prefix": "define",
        "body": "(define ${1:name} ${0:value})",
        "description": "Define a variable"
    },
    "Lambda": {
        "prefix": "lambda",
        "body": [
            "(lambda (${1:args})",
            "  $0)"
        ],
        "description": "Anonymous function"
    },
    "Let": {
        "prefix": "let",
        "body": [
            "(let ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Parallel local bindings"
    },
    "Let*": {
        "prefix": "let*",
        "body": [
            "(let* ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Sequential local bindings"
    },
    "Letrec": {
        "prefix": "letrec",
        "body": [
            "(letrec ((${1:var} ${2:init}))",
            "  $0)"
        ],
        "description": "Recursive local bindings"
    },
    "If": {
        "prefix": "if",
        "body": "(if ${1:test}\n    ${2:consequent}\n    ${0:alternate})",
        "description": "Conditional expression"
    },
    "Cond": {
        "prefix": "cond",
        "body": [
            "(cond",
            "  (${1:test} ${2:expr})",
            "  (else ${0:default}))"
        ],
        "description": "Multi-way conditional"
    },
    "Case": {
        "prefix": "case",
        "body": [
            "(case ${1:key}",
            "  ((${2:datum}) ${3:expr})",
            "  (else ${0:default}))"
        ],
        "description": "Dispatch on datum equality"
    },
    "When": {
        "prefix": "when",
        "body": [
            "(when ${1:test}",
            "  $0)"
        ],
        "description": "One-armed conditional (when test is true)"
    },
    "Unless": {
        "prefix": "unless",
        "body": [
            "(unless ${1:test}",
            "  $0)"
        ],
        "description": "One-armed conditional (when test is false)"
    },
    "Define Record Type": {
        "prefix": "define-record-type",
        "body": [
            "(define-record-type ${1:name}",
            "  (${2:make-${1:name}} ${3:field1} ${4:field2})",
            "  ${5:${1:name}?}",
            "  (${3:field1} ${1:name}-${3:field1} set-${1:name}-${3:field1}!)",
            "  (${4:field2} ${1:name}-${4:field2} set-${1:name}-${4:field2}!))$0"
        ],
        "description": "Record type with predicate, accessors, and setters"
    },
    "Import": {
        "prefix": "import",
        "body": "(import ${1|std.prelude,std.io,std.core,std.collections,std.math,std.logic,std.freeze,std.clp,std.clpr,std.clpb,std.db,std.aad,std.torch,std.stats,std.hashmap,std.hashset,std.regex,std.csv,std.net,std.supervisor,std.test,std.time|})",
        "description": "Import bindings from a module"
    },
    "Catch": {
        "prefix": "catch",
        "body": [
            "(catch '${1:tag}",
            "  $0)"
        ],
        "description": "Catch exceptions with a tag"
    },
    "Raise": {
        "prefix": "raise",
        "body": "(raise '${1:tag} ${0:value})",
        "description": "Raise an exception with a tag"
    },
    "Define Syntax": {
        "prefix": "define-syntax",
        "body": [
            "(define-syntax ${1:name}",
            "  (syntax-rules ()",
            "    ((${1:name} ${2:pattern})",
            "     ${0:template})))"
        ],
        "description": "Define a hygienic macro"
    },
    "Do": {
        "prefix": "do",
        "body": [
            "(do ((${1:var} ${2:init} ${3:step}))",
            "    ((${4:test}) ${5:result})",
            "  $0)"
        ],
        "description": "Iteration construct"
    },

    "Regex Compile": {
        "prefix": "regex-compile",
        "body": "(define ${1:rx} (regex:compile \"${2:pattern}\" ${3:'icase}))",
        "description": "Compile a reusable regex handle"
    },
    "Regex Match": {
        "prefix": "regex-match",
        "body": "(regex:match? ${1:regex-or-pattern} ${2:string})",
        "description": "Run a full-string regex match"
    },
    "Regex Replace Fn": {
        "prefix": "regex-replace-fn",
        "body": [
            "(regex:replace-fn ${1:regex-or-pattern} ${2:string}",
            "  (lambda (${3:m})",
            "    ${0:(regex-match-text m)}))"
        ],
        "description": "Replace each match via callback"
    },
    "Regex Find All": {
        "prefix": "regex-find-all",
        "body": [
            "(define ${1:matches}",
            "  (regex:find-all ${2:regex-or-pattern} ${3:string}))",
            "$0"
        ],
        "description": "Collect all regex match payloads"
    },

    "CSV Open Reader": {
        "prefix": "csv-open-reader",
        "body": [
            "(define ${1:r} (csv:open-reader \"${2:data.csv}\"${3: :delimiter #\\;}))",
            "$0"
        ],
        "description": "Open a CSV reader with optional keyword options"
    },
    "CSV Fold": {
        "prefix": "csv-fold",
        "body": [
            "(csv:fold ${1:reader}",
            "  (lambda (${2:acc} ${3:row})",
            "    ${4:(f acc row)})",
            "  ${5:init})"
        ],
        "description": "Stream CSV records with a fold"
    },
    "CSV Write Record": {
        "prefix": "csv-write-record",
        "body": [
            "(csv:write-record ${1:writer} ${2:record} ${3:columns})",
            "$0"
        ],
        "description": "Write one record with explicit column ordering"
    },

    "Hash Map": {
        "prefix": "hash-map",
        "body": "(hash-map ${1:'key1} ${2:value1} ${3:'key2} ${4:value2})",
        "description": "Construct a hash map from key/value pairs"
    },
    "Hash Set": {
        "prefix": "hash-set",
        "body": "(hash-set ${1:value1} ${2:value2} ${3:value3})",
        "description": "Construct a hash set from values"
    },
    "Hash Map Fold": {
        "prefix": "hash-map-fold",
        "body": [
            "(hash-map-fold",
            "  (lambda (${1:acc} ${2:key} ${3:value})",
            "    ${4:acc})",
            "  ${5:init}",
            "  ${6:map})"
        ],
        "description": "Fold a hash map with accumulator, key, and value"
    },

    "Import Net": {
        "prefix": "import-net",
        "body": "(import std.net)",
        "description": "Import the networking / message-passing module"
    },
    "NNG Socket": {
        "prefix": "nng-socket",
        "body": [
            "(define ${1:sock} (nng-socket '${2|pair,pub,sub,push,pull,req,rep,surveyor,respondent,bus|}))",
            "(nng-${3|listen,dial|} ${1:sock} \"${4:tcp://localhost:5555}\")",
            "$0"
        ],
        "description": "Create and listen/dial an nng socket"
    },
    "With Socket": {
        "prefix": "with-socket",
        "body": [
            "(with-socket '${1|pair,req,rep,pub,sub,push,pull,surveyor,respondent,bus|}",
            "  (lambda (${2:sock})",
            "    (nng-dial ${2:sock} \"${3:tcp://localhost:5555}\")",
            "    $0))"
        ],
        "description": "Safe socket with automatic dynamic-wind cleanup"
    },
    "Spawn Worker": {
        "prefix": "spawn",
        "body": [
            "(define ${1:worker} (spawn \"${2:worker.eta}\"))",
            "(send! ${1:worker} ${3:'(task)})",
            "(define ${4:result} (recv! ${1:worker} 'wait))",
            "(spawn-wait ${1:worker})",
            "(nng-close ${1:worker})",
            "$0"
        ],
        "description": "Spawn a child process, send a message, receive the result, and clean up"
    },
    "Spawn Thread": {
        "prefix": "spawn-thread",
        "body": [
            "(define ${1:t}",
            "  (spawn-thread",
            "    (lambda ()",
            "      (let loop ()",
            "        (let ((${2:msg} (recv! (current-mailbox) 'wait)))",
            "          ${3:(display msg) (newline)}",
            "          (loop))))))",
            "$0"
        ],
        "description": "Spawn an in-process actor thread with a recv loop on its mailbox"
    },
    "Spawn Thread With": {
        "prefix": "spawn-thread-with",
        "body": [
            "(define ${1:t} (spawn-thread-with ${2:state}",
            "  (lambda (${3:state} ${4:msg})",
            "    ${0:(values state)})))"
        ],
        "description": "Spawn an actor with explicit state-passing receive loop"
    },
    "Send/Recv": {
        "prefix": "send-recv",
        "body": [
            "(send! ${1:sock} ${2:value})",
            "(define ${3:reply} (recv! ${1:sock} 'wait))",
            "$0"
        ],
        "description": "Send a message and wait for a reply"
    },
    "Worker Pool": {
        "prefix": "worker-pool",
        "body": [
            "(define ${1:results} (worker-pool \"${2:worker.eta}\" ${3:tasks}))",
            "$0"
        ],
        "description": "Distribute tasks across a pool of worker processes and collect results"
    },
    "Request Reply": {
        "prefix": "request-reply",
        "body": [
            "(define ${1:result} (request-reply \"${2:tcp://localhost:5555}\" ${3:message}))",
            "$0"
        ],
        "description": "Synchronous one-shot request-reply over a REQ socket"
    },
    "Current Mailbox": {
        "prefix": "current-mailbox",
        "body": [
            "(define ${1:mailbox} (current-mailbox))",
            "(define ${2:msg} (recv! ${1:mailbox} 'wait))",
            "$0"
        ],
        "description": "Receive the parent socket inside a spawned child process"
    },

    "Supervisor One-For-One": {
        "prefix": "one-for-one",
        "body": [
            "(one-for-one",
            "  (list",
            "    (list '${1:child-name} \"${2:child.eta}\" ${3:'()})",
            "    $0))"
        ],
        "description": "Restart-on-crash supervisor: only the failed child restarts"
    },
    "Supervisor One-For-All": {
        "prefix": "one-for-all",
        "body": [
            "(one-for-all",
            "  (list",
            "    (list '${1:child-name} \"${2:child.eta}\" ${3:'()})",
            "    $0))"
        ],
        "description": "Restart-on-crash supervisor: any failure restarts every child"
    },

    "Logic findall": {
        "prefix": "findall",
        "body": [
            "(define ${1:q} (logic-var))",
            "(define ${2:results}",
            "  (findall (lambda () (deref-lvar ${1:q}))",
            "    ${3:(some-goal ${1:q})}))",
            "$0"
        ],
        "description": "Collect all solutions of a logic goal into a list"
    },
    "Logic run*": {
        "prefix": "run*",
        "body": [
            "(run* (${1:q})",
            "  ${0:(== ${1:q} 'value)})"
        ],
        "description": "Run a relational query and collect every answer"
    },
    "Logic run1": {
        "prefix": "run1",
        "body": [
            "(run1 (${1:q})",
            "  ${0:(== ${1:q} 'value)})"
        ],
        "description": "Run a relational query and return the first answer"
    },
    "Logic run-n": {
        "prefix": "run-n",
        "body": [
            "(run-n ${1:5} (${2:q})",
            "  ${0:(== ${2:q} 'value)})"
        ],
        "description": "Run a relational query bounded to N answers"
    },
    "Logic conde": {
        "prefix": "conde",
        "body": [
            "(conde",
            "  (${1:goal-1a} ${2:goal-1b})",
            "  (${3:goal-2a} ${4:goal-2b}))$0"
        ],
        "description": "Disjunction of conjunctions (miniKanren-style)"
    },
    "Logic fresh": {
        "prefix": "fresh",
        "body": [
            "(fresh (${1:x} ${2:y})",
            "  ${0:(== ${1:x} ${2:y})})"
        ],
        "description": "Introduce fresh logic variables in a goal scope"
    },
    "Logic defrel": {
        "prefix": "defrel",
        "body": [
            "(defrel '(${1:name} ${2:?a} ${3:?b}))$0"
        ],
        "description": "Declare a relation in the in-memory deductive database"
    },
    "Logic tabled": {
        "prefix": "tabled",
        "body": [
            "(tabled '${1:relation} ${2:arity})$0"
        ],
        "description": "Mark a relation as tabled (memoised) for SLG-style evaluation"
    },
    "Logic freeze": {
        "prefix": "freeze",
        "body": [
            "(freeze ${1:lvar}",
            "  (lambda ()",
            "    ${0:(== ${1:lvar} 'fired)}))"
        ],
        "description": "Suspend a goal until the logic variable is bound"
    },
    "Logic dif": {
        "prefix": "dif",
        "body": "(dif ${1:x} ${2:y})$0",
        "description": "Constructive inequality constraint between two terms"
    },

    "CLP(FD) Domain": {
        "prefix": "clp-domain",
        "body": "(clp:domain ${1:var} ${2:0} ${3:9})$0",
        "description": "Restrict an FD variable to an integer interval"
    },
    "CLP(FD) Solve": {
        "prefix": "clp-solve",
        "body": [
            "(clp:labeling ${1:vars} 'strategy '${2|ff,leftmost,middle-out|})$0"
        ],
        "description": "Search for solutions to posted FD constraints"
    },
    "CLP(FD) All Different": {
        "prefix": "clp-all-different",
        "body": "(clp:all-different ${1:vars})$0",
        "description": "Pairwise-distinct constraint over a list of FD variables"
    },
    "CLP(R) Linear Maximize": {
        "prefix": "clpr-maximize",
        "body": [
            "(import std.clpr)",
            "(define ${1:weights} (list ${2:(clp:r-var) (clp:r-var)}))",
            "(clp:r=  (dot '(1 1) ${1:weights}) 1.0)",
            "(clp:r-maximize (dot ${3:returns} ${1:weights}))$0"
        ],
        "description": "Linear-programming maximisation skeleton with simplex backend"
    },
    "CLP(B) Boolean Solve": {
        "prefix": "clpb-solve",
        "body": [
            "(import std.clpb)",
            "(define ${1:vars} (list ${2:(clp:b-var) (clp:b-var)}))",
            "(clp:b-sat ${3:formula})",
            "(clp:b-labeling ${1:vars})$0"
        ],
        "description": "Boolean SAT/labelling skeleton on top of CLP(B)"
    },

    "AAD Gradient": {
        "prefix": "grad",
        "body": [
            "(grad (lambda (${1:x} ${2:y}) ${3:(+ (* ${1:x} ${2:y}) (sin ${1:x}))})",
            "      '(${4:2} ${5:3}))$0"
        ],
        "description": "Reverse-mode gradient of a numeric function (std.aad)"
    },
    "AAD Tape Block": {
        "prefix": "tape",
        "body": [
            "(let ((${1:tape} (tape-new)))",
            "  (let ((${2:x} (tape-var ${1:tape} ${3:1.0})))",
            "    (tape-start! ${1:tape})",
            "    (let ((${4:out} ${5:(* ${2:x} ${2:x})}))",
            "      (tape-stop!)",
            "      (tape-backward! ${1:tape} ${4:out})",
            "      (list (tape-primal ${1:tape} ${4:out})",
            "            (tape-adjoint ${1:tape} ${2:x})))))$0"
        ],
        "description": "Low-level reverse-mode AD tape: var, record, backward, read adjoint"
    },

    "Torch Tensor": {
        "prefix": "tensor",
        "body": "(tensor ${1:'((1.0 2.0) (3.0 4.0))})$0",
        "description": "Build a tensor from a nested numeric list"
    },
    "Torch Backward": {
        "prefix": "backward",
        "body": [
            "(define ${1:x} (requires-grad! (tensor ${2:1.0})))",
            "(define ${3:y} ${4:(* ${1:x} ${1:x})})",
            "(backward ${3:y})",
            "(grad ${1:x})$0"
        ],
        "description": "Construct a leaf tensor, run forward, backprop, read gradient"
    },

    "Test Group": {
        "prefix": "test-group",
        "body": [
            "(test-group \"${1:group name}\"",
            "  (test \"${2:case name}\"",
            "    (assert-equal ${3:expected} ${4:actual}))$0)"
        ],
        "description": "Test group with an initial assert-equal case (std.test)"
    }
}

