{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "out",
        "types": ["mocha", "node"],
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["src/**/*", "test/**/*"],
    "exclude": ["node_modules", ".vscode-test", "out"]
}

