{
    "name": "eta-scheme-lang",
    "displayName": "Eta (Scheme) Language",
    "description": "Language support for the Eta-Scheme programming language",
    "version": "0.4.14",
    "publisher": "eta-schema-lang",
    "icon": "media/eta_logo.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/eta-lang/eta"
    },
    "bugs": {
        "url": "https://github.com/eta-lang/eta/issues"
    },
    "homepage": "https://github.com/eta-lang/eta#readme",
    "galleryBanner": {
        "color": "#0f172a",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Snippets"
    ],
    "keywords": [
        "eta",
        "lisp",
        "scheme",
        "functional",
        "logic-programming",
        "unification"
    ],
    "license": "Apache-2.0",
    "activationEvents": [
        "onLanguage:eta",
        "onDebugResolve:eta",
        "workspaceContains:**/*.test.eta"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "eta",
                "aliases": [
                    "Eta",
                    "eta"
                ],
                "extensions": [
                    ".eta"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "eta",
                "scopeName": "source.eta",
                "path": "./syntaxes/eta.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "eta",
                "path": "./snippets/eta.json"
            }
        ],
        "views": {
            "debug": [
                {
                    "id": "etaGCRoots",
                    "name": "Memory",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(list-tree)"
                },
                {
                    "id": "etaDisassembly",
                    "name": "Disassembly",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(file-binary)"
                },
                {
                    "id": "etaChildProcesses",
                    "name": "Child Processes",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(server-process)"
                }
            ]
        },
        "configuration": {
            "title": "Eta",
            "properties": {
                "eta.modulePath": {
                    "type": "string",
                    "default": "",
                    "description": "Colon/semicolon-separated list of directories to search for Eta modules (ETA_MODULE_PATH). Used by both the LSP and DAP servers. Falls back to eta.lsp.modulePath, then to the ETA_MODULE_PATH environment variable."
                },
                "eta.lsp.serverPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the eta_lsp executable. If empty, searches PATH."
                },
                "eta.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable the Eta Language Server for diagnostics and IDE features."
                },
                "eta.dap.executablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Full path to the eta_dap executable OR the directory containing it (e.g. C:\\Eta\\bin or C:\\Eta\\bin\\eta_dap.exe). If empty, searches next to eta_lsp, then workspace build output, then PATH."
                },
                "eta.binaries.searchPaths": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Additional directories or executable paths searched for Eta binaries. Supports ${workspaceFolder} token."
                },
                "eta.debug.autoShowHeap": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically show the Heap Inspector when a debug session starts (when heap auto-refresh is enabled)."
                },
                "eta.debug.autoShowDisassembly": {
                    "type": "boolean",
                    "default": false,
                    "description": "On every stopped event, also open the bytecode disassembly side-by-side and reveal the current PC line."
                },
                "eta.debug.autoRefreshViewsOnStop": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically refresh debug side views on each stop. Disabled by default for debugger responsiveness; enable only if your eta_dap build handles stop-time custom requests reliably."
                },
                "eta.debug.autoRefreshHeapOnStop": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically refresh Heap Inspector data on each stop. Enable only when your eta_dap build includes bounded heap snapshot support."
                },
                "eta.debug.autoRefreshDisassemblyOnStop": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically refresh disassembly side views/documents on each stop."
                },
                "eta.debug.inlineValuesEnabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable inline values in the editor while paused. Disabled by default because stop-time evaluate requests can impact debug responsiveness on large programs."
                },
                "eta.test.runnerPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the eta_test executable OR the directory containing it. If empty, searches workspace build output directories and then PATH."
                }
            }
        },
        "commands": [
            {
                "command": "eta.runFile",
                "title": "Run Eta File",
                "icon": "$(play)",
                "category": "Eta"
            },
            {
                "command": "eta.debugFile",
                "title": "Debug Eta File",
                "icon": "$(debug-alt)",
                "category": "Eta"
            },
            {
                "command": "eta.runTestFile",
                "title": "Run Tests in Current File",
                "icon": "$(beaker)",
                "category": "Eta"
            },
            {
                "command": "eta.showHeapInspector",
                "title": "Show Heap Inspector",
                "icon": "$(database)",
                "category": "Eta"
            },
            {
                "command": "eta.showDisassembly",
                "title": "Show Disassembly",
                "icon": "$(file-binary)",
                "category": "Eta"
            },
            {
                "command": "eta.showDisassemblyAll",
                "title": "Show Disassembly (All Functions)",
                "icon": "$(file-binary)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshGCRoots",
                "title": "Refresh Memory",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshDisassembly",
                "title": "Refresh Disassembly",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshChildProcesses",
                "title": "Refresh Child Processes",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.inspectObjectFromTree",
                "title": "Inspect Object",
                "category": "Eta"
            },
            {
                "command": "eta.disassembly.gotoCallee",
                "title": "Go to Callee",
                "category": "Eta"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "eta.runFile",
                    "when": "resourceLangId == eta",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "eta.runFile",
                    "when": "resourceLangId == eta"
                },
                {
                    "command": "eta.debugFile",
                    "when": "resourceLangId == eta"
                },
                {
                    "command": "eta.runTestFile",
                    "when": "resourceLangId == eta && resourceFilename =~ /\\.test\\.eta$/"
                },
                {
                    "command": "eta.showHeapInspector"
                },
                {
                    "command": "eta.showDisassembly",
                    "when": "debugType == 'eta'"
                },
                {
                    "command": "eta.showDisassemblyAll",
                    "when": "debugType == 'eta'"
                },
                {
                    "command": "eta.inspectObjectFromTree",
                    "when": "false"
                },
                {
                    "command": "eta.disassembly.gotoCallee",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "eta.refreshGCRoots",
                    "when": "view == etaGCRoots",
                    "group": "navigation"
                },
                {
                    "command": "eta.refreshDisassembly",
                    "when": "view == etaDisassembly",
                    "group": "navigation"
                },
                {
                    "command": "eta.refreshChildProcesses",
                    "when": "view == etaChildProcesses",
                    "group": "navigation"
                }
            ]
        },
        "breakpoints": [
            {
                "language": "eta"
            }
        ],
        "debuggers": [
            {
                "type": "eta",
                "label": "Eta",
                "languages": [
                    "eta"
                ],
                "breakpoints": [
                    {
                        "language": "eta"
                    }
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Absolute path to the .eta file to run.",
                                "default": "${file}"
                            },
                            "args": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Command-line arguments forwarded to Eta launch handling."
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for the Eta debug adapter process.",
                                "default": "${workspaceFolder}"
                            },
                            "env": {
                                "type": "object",
                                "description": "Environment variables passed to the Eta debug adapter process.",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            },
                            "modulePath": {
                                "type": "string",
                                "description": "Module search path override (ETA_MODULE_PATH) for this debug session."
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Pause on the first instruction when launching.",
                                "default": false
                            },
                            "etac": {
                                "type": "boolean",
                                "description": "Launch a precompiled .etac artifact when supported by the adapter.",
                                "default": false
                            },
                            "console": {
                                "type": "string",
                                "enum": [
                                    "debugConsole",
                                    "integratedTerminal",
                                    "externalTerminal"
                                ],
                                "default": "debugConsole",
                                "description": "Preferred console target for session output."
                            },
                            "trace": {
                                "type": "boolean",
                                "default": false,
                                "description": "Enable DAP protocol tracing by launching eta_dap with --trace-protocol."
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "eta",
                        "request": "launch",
                        "name": "Run Eta file",
                        "program": "${file}",
                        "stopOnEntry": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Eta: Launch",
                        "description": "Run an Eta source file with the Eta debug adapter.",
                        "body": {
                            "type": "eta",
                            "request": "launch",
                            "name": "Run Eta file",
                            "program": "^\"\\${file}\"",
                            "stopOnEntry": false
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle",
        "compile": "tsc -p ./",
        "compile-tests": "tsc -p ./tsconfig.test.json",
        "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
        "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
        "package": "npm run bundle && vsce package",
        "pretest": "npm run compile-tests",
        "test": "vscode-test"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.2.0",
        "esbuild": "^0.25.0",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "typescript": "^5.3.0"
    }
}
