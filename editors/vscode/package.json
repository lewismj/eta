{
    "name": "eta-lang",
    "displayName": "Eta Language",
    "description": "Language support for the Eta programming language",
    "version": "0.3.0",
    "publisher": "eta-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/eta-lang/eta"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": ["Programming Languages"],
    "keywords": ["eta", "lisp", "scheme", "functional", "logic-programming", "unification"],
    "license": "MIT",
    "activationEvents": [
        "onLanguage:eta",
        "onDebugResolve:eta",
        "onCommand:eta.runFile",
        "onCommand:eta.showHeapInspector",
        "onCommand:eta.showDisassembly",
        "onView:etaGCRoots",
        "onView:etaDisassembly",
        "onView:etaChildProcesses"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [{
            "id": "eta",
            "aliases": ["Eta", "eta"],
            "extensions": [".eta"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "eta",
            "scopeName": "source.eta",
            "path": "./syntaxes/eta.tmLanguage.json"
        }],
        "snippets": [{
            "language": "eta",
            "path": "./snippets/eta.json"
        }],
            "views": {
            "debug": [
                {
                    "id": "etaGCRoots",
                    "name": "Memory",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(list-tree)"
                },
                {
                    "id": "etaDisassembly",
                    "name": "Disassembly",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(file-binary)"
                },
                {
                    "id": "etaChildProcesses",
                    "name": "Child Processes",
                    "when": "inDebugMode && debugType == 'eta'",
                    "icon": "$(server-process)"
                }
            ]
        },
        "configuration": {
            "title": "Eta",
            "properties": {
                "eta.modulePath": {
                    "type": "string",
                    "default": "",
                    "description": "Colon/semicolon-separated list of directories to search for Eta modules (ETA_MODULE_PATH). Used by both the LSP and DAP servers. Falls back to eta.lsp.modulePath, then to the ETA_MODULE_PATH environment variable."
                },
                "eta.lsp.serverPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the eta_lsp executable. If empty, searches PATH."
                },
                "eta.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable the Eta Language Server for diagnostics and IDE features."
                },
                "eta.lsp.modulePath": {
                    "type": "string",
                    "default": "",
                    "description": "Deprecated — use eta.modulePath instead. Colon/semicolon-separated list of directories to search for Eta modules."
                },
                "eta.dap.executablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Full path to the eta_dap executable OR the directory containing it (e.g. C:\\Eta\\bin or C:\\Eta\\bin\\eta_dap.exe). If empty, searches next to eta_lsp, then workspace build output, then PATH."
                },
                "eta.debug.autoShowHeap": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically show the Heap Inspector when a debug session starts."
                }
            }
        },
        "commands": [
            {
                "command": "eta.runFile",
                "title": "Run Eta File",
                "icon": "$(play)",
                "category": "Eta"
            },
            {
                "command": "eta.showHeapInspector",
                "title": "Show Heap Inspector",
                "icon": "$(database)",
                "category": "Eta"
            },
            {
                "command": "eta.showDisassembly",
                "title": "Show Disassembly",
                "icon": "$(file-binary)",
                "category": "Eta"
            },
            {
                "command": "eta.showDisassemblyAll",
                "title": "Show Disassembly (All Functions)",
                "icon": "$(file-binary)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshGCRoots",
                "title": "Refresh GC Roots",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshDisassembly",
                "title": "Refresh Disassembly",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.refreshChildProcesses",
                "title": "Refresh Child Processes",
                "icon": "$(refresh)",
                "category": "Eta"
            },
            {
                "command": "eta.inspectObjectFromTree",
                "title": "Inspect Object",
                "category": "Eta"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "eta.runFile",
                    "when": "resourceLangId == eta",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "eta.runFile",
                    "when": "resourceLangId == eta"
                },
                {
                    "command": "eta.showHeapInspector"
                },
                {
                    "command": "eta.showDisassembly",
                    "when": "debugType == 'eta'"
                },
                {
                    "command": "eta.showDisassemblyAll",
                    "when": "debugType == 'eta'"
                },
                {
                    "command": "eta.inspectObjectFromTree",
                    "when": "false"
                }
            ],
            "view/title": [
                {
                    "command": "eta.refreshGCRoots",
                    "when": "view == etaGCRoots",
                    "group": "navigation"
                },
                {
                    "command": "eta.refreshDisassembly",
                    "when": "view == etaDisassembly",
                    "group": "navigation"
                },
                {
                    "command": "eta.refreshChildProcesses",
                    "when": "view == etaChildProcesses",
                    "group": "navigation"
                }
            ]
        },
        "breakpoints": [
            { "language": "eta" }
        ],
        "debuggers": [
            {
                "type": "eta",
                "label": "Eta",
                "languages": ["eta"],
                "breakpoints": [
                    { "language": "eta" }
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": ["program"],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Absolute path to the .eta file to run.",
                                "default": "${file}"
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Pause on the first instruction when launching.",
                                "default": false
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "eta",
                        "request": "launch",
                        "name": "Run Eta file",
                        "program": "${file}",
                        "stopOnEntry": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Eta: Launch",
                        "description": "Run an Eta source file with the Eta debug adapter.",
                        "body": {
                            "type": "eta",
                            "request": "launch",
                            "name": "Run Eta file",
                            "program": "^\"\\${file}\"",
                            "stopOnEntry": false
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle",
        "compile": "tsc -p ./",
        "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
        "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
        "package": "npm run bundle && vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0",
        "@vscode/vsce": "^3.2.0",
        "esbuild": "^0.25.0"
    }
}
