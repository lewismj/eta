{
    "comments": {
        "lineComment": ";",
        "blockComment": ["#|", "|#"]
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "[", "close": "]" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "#|", "close": "|#" }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["\"", "\""]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*\\((?!.*\\)).*$",
        "decreaseIndentPattern": "^\\s*\\).*$"
    },
    "folding": {
        "markers": {
            "start": "^\\s*#\\|",
            "end": "\\|#\\s*$"
        }
    },
    "onEnterRules": [
        {
            "beforeText": "^.*\\([^)]*$",
            "action": { "indent": "indent" }
        },
        {
            "beforeText": "^\\s*\\)\\s*$",
            "action": { "indent": "outdent" }
        }
    ],
    "wordPattern": "[^\\s()\\[\\]{}\",'`;#|\\\\]+"
}

